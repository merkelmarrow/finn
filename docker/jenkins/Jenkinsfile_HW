// HW-tethered pipeline. One row per board in HW_SHARDS, mirroring the
// PARALLEL_SHARDS pattern in docker/jenkins/Jenkinsfile.
//
// Shared helpers (safeStashReport, aggregateReports, unstashIfPresent,
// cleanPreviousBuildFiles) are duplicated from Jenkinsfile because Jenkins
// declarative pipelines have no shared-library hook here. Keep in sync.

import groovy.transform.Field

@Field
List<Map> HW_SHARDS = [
    [board: 'U250',      agentLabel: 'finn-u250',  credentialsId: null,
     restartPrep: false, setupScript: 'alveo',  marker: 'U250'],
    [board: 'Pynq-Z1',   agentLabel: 'finn-pynq',  credentialsId: 'pynq-z1-credentials',
     restartPrep: true,  setupScript: 'pynq',   marker: 'Pynq'],
    [board: 'ZCU104',    agentLabel: 'finn-zcu104', credentialsId: 'pynq-z1-credentials',
     restartPrep: true,  setupScript: 'pynq',   marker: 'ZCU104'],
    [board: 'KV260_SOM', agentLabel: 'finn-kv260', credentialsId: 'user-ubuntu-credentials',
     restartPrep: true,  setupScript: 'pynq',   marker: 'KV260_SOM'],
]

@Field
List<String> HW_TEST_TYPES = ['bnn_build_sanity', 'bnn_build_full']

// Populated by refreshNodeOnlineFlags() and read by isOnline(). Keyed by
// agentLabel so HW_SHARDS rows are the single source of truth.
@Field
Map<String, Boolean> NODE_ONLINE = [:]

pipeline {
  agent none
  stages {
    stage('Get node status') {
      options { skipDefaultCheckout() }
      agent { label 'finn-build' }
      steps { script { refreshNodeOnlineFlags() } }
    }
    stage('Reboot Zynq platforms') {
      steps { script { parallel(buildRebootMap()) } }
    }
    stage('Wait for Nodes to reboot') {
      options { skipDefaultCheckout() }
      agent { label 'finn-build' }
      steps { sleep(time: "${env.REBOOT_SLEEP}", unit: 'MINUTES') }
    }
    stage('Collect build information for HW testing') {
      options { skipDefaultCheckout() }
      agent { label 'finn-build' }
      steps { script { collectBuildArtifacts() } }
    }
    stage('Sanity - Run Hardware Tests') {
      steps { script { parallel(buildHwStageMap('bnn_build_sanity')) } }
    }
    stage('End2end - Run Hardware Tests') {
      steps { script { parallel(buildHwStageMap('bnn_build_full')) } }
    }
    stage('Check Stage Results') {
      agent { label 'finn-build' }
      steps { script { aggregateReports() } }
    }
  }
}

void refreshNodeOnlineFlags() {
  HW_SHARDS.each { row ->
    NODE_ONLINE[row.agentLabel as String] = isNodeOnline(row.agentLabel as String)
  }
}

boolean isOnline(String agentLabel) {
  Boolean v = NODE_ONLINE[agentLabel]
  return v != null && v
}

// One parallel reboot per board with restartPrep=true. Offline boards
// are skipped inside runReboot().
Map<String, Closure> buildRebootMap() {
  def branches = [:]
  HW_SHARDS.each { row ->
    if (!row.restartPrep) { return }
    String stage = row.board == 'KV260_SOM' ? "Kria ${row.board}" : row.board
    branches[stage] = { runReboot(row, stage) }
  }
  return branches
}

void runReboot(Map row, String stageName) {
  if (!isOnline(row.agentLabel as String)) {
    echo "${stageName} reboot skipped: agent ${row.agentLabel} offline"
    return
  }
  node(row.agentLabel) {
    stage(stageName) {
      catchError(stageResult: 'FAILURE') {
        withHwCredentials(row) {
          restartZynqPlatform()
        }
      }
    }
  }
}

void collectBuildArtifacts() {
  refreshNodeOnlineFlags()
  dir('docker/jenkins') {
    stash name: 'bnn_test_files', includes: 'test_bnn_hw_pytest.py'
  }
  HW_TEST_TYPES.each { testType -> stashBuildArtifacts(testType) }
}

Map<String, Closure> buildHwStageMap(String testType) {
  String label = testType == 'bnn_build_sanity' ? 'Sanity' : 'end2end'
  def branches = [:]
  HW_SHARDS.each { row ->
    String stage = "BNN ${label} - ${row.board}"
    branches[stage] = { runHwShard(row, testType, stage) }
  }
  return branches
}

// Mirrors runShard() in Jenkinsfile. safeStashReport in `finally` so failed
// stages still publish their junit XML.
void runHwShard(Map row, String testType, String stageName) {
  if (!isOnline(row.agentLabel as String)) {
    echo "${stageName} skipped: agent ${row.agentLabel} offline"
    return
  }
  node(row.agentLabel) {
    stage(stageName) {
      String stash = hwStashName(testType, row.board as String)
      try {
        catchError(stageResult: 'FAILURE') {
          withHwCredentials(row) {
            runHwTest(row, testType)
          }
        }
      } finally {
        dir("${testType}/${row.board}") {
          safeStashReport(stash, "${testType}_hw_${row.board}")
        }
        withHwCredentials(row) { cleanUpWorkspaceOwnership() }
      }
    }
  }
}

// Boards with credentialsId get a withCredentials wrapper -- alveo has none.
void withHwCredentials(Map row, Closure body) {
  if (!row.credentialsId) {
    body.call()
    return
  }
  withCredentials([usernamePassword(
      credentialsId: row.credentialsId as String,
      usernameVariable: 'USER_CREDENTIALS_USR',
      passwordVariable: 'USER_CREDENTIALS_PSW')]) {
    withEnv(['USER_CREDENTIALS=true']) {
      body.call()
    }
  }
}

void runHwTest(Map row, String testType) {
  sh "mkdir -p ${testType}"
  dir("${testType}") {
    cleanPreviousBuildFiles("${row.board}*")
    unstash name: "${testType}_${row.board}_zip"
    sh "unzip -o ${row.board}.zip"
    dir("${row.board}") {
      unstash name: 'bnn_test_files'
      createTestScript(row, "${testType}_hw_${row.board}")
      if (env.USER_CREDENTIALS) {
        sh 'echo ${USER_CREDENTIALS_PSW} | sudo -S ./run-tests.sh'
      } else {
        sh './run-tests.sh'
      }
    }
  }
}

// Marker is passed via env var (not interpolated) so shell metachars
// in a malformed marker can't escape.
void createTestScript(Map row, String testResultsFilename) {
  String setup = (row.setupScript == 'alveo')
      ? '. /opt/xilinx/xrt/setup.sh\n. ${VENV_ACTIVATE}'
      : '. /etc/profile.d/pynq_venv.sh\n. /etc/profile.d/xrt_setup.sh'
  String script =
      "#!/bin/bash\n${setup}\n" +
      "export FINN_CI_MARKER='${row.marker}'\n" +
      "python -m pytest -m \"\$FINN_CI_MARKER\" " +
      "--junitxml=${testResultsFilename}.xml --html=${testResultsFilename}.html " +
      "--self-contained-html\n"
  writeFile file: 'run-tests.sh', text: script
  sh 'chmod 777 run-tests.sh'
}

String hwStashName(String testType, String board) {
  return "${testType}_${board}"
}

// Find the newest <board>.zip across the legacy fixed path, the
// sanity-build single-dir, and the per-shard full-build dirs. Returns ""
// when no zip is found, in which case the caller logs and skips that shard.
String findBoardZip(String testType, String board) {
  String legacy = "${env.ARTIFACT_DIR}/${testType}/${board}.zip"
  if (fileExists(legacy)) { return legacy }
  String glob = (testType == 'bnn_build_sanity')
      ? "${env.ARTIFACT_DIR}/sanity_build_hardware/${board}.zip"
      : "${env.ARTIFACT_DIR}/bnn_*/${board}.zip"
  def hit = sh(returnStdout: true, script:
      "ls -1t ${glob} 2>/dev/null | head -1 || true"
  ).trim()
  return hit
}

void stashBuildArtifacts(String testType) {
  HW_SHARDS.each { row ->
    String board = row.board as String
    if (!isOnline(row.agentLabel as String)) {
      echo "stashBuildArtifacts[${testType}]: ${board} agent offline, skipping"
      return
    }
    String src = findBoardZip(testType, board)
    if (!src) {
      echo "stashBuildArtifacts[${testType}]: no ${board}.zip under ${env.ARTIFACT_DIR}, HW shard for ${board}/${testType} will skip"
      return
    }
    echo "stashBuildArtifacts[${testType}]: ${board} <- ${src}"
    // stash is workspace-relative, so copy into workspace first.
    sh "cp '${src}' '${board}.zip'"
    stash name: "${testType}_${board}_zip", includes: "${board}.zip"
    sh "rm -f '${board}.zip'"
  }
}

// Filtered by agentLabel so offline boards don't appear in the expected
// stash set (avoids spurious unstash warnings).
List<String> expectedStashes() {
  def stashes = []
  HW_TEST_TYPES.each { testType ->
    HW_SHARDS.each { row ->
      if (isOnline(row.agentLabel as String)) {
        stashes << hwStashName(testType, row.board as String)
      }
    }
  }
  return stashes
}

// Used for offline-agent gating and for filtering expectedStashes.
def isNodeOnline(String labelName) {
  Label label = Jenkins.instance.getLabel(labelName)
  def agentOnline = false
  if (label) {
    List<Node> nodes = Jenkins.instance.getNodes()
    nodes.each { node ->
      if (node.getAssignedLabels().contains(label)) {
        def computer = node.toComputer()
        if (computer && computer.isOnline()) {
          agentOnline = true
        } else {
          echo "Agent ${node.displayName} is offline"
        }
      }
    }
  } else {
    echo "Node with label ${labelName} not found"
  }
  return agentOnline
}

// --------------------------------------------------------------------------
// Shared helpers — DUPLICATED from docker/jenkins/Jenkinsfile. Keep in sync.
// --------------------------------------------------------------------------

void safeStashReport(String stashName, String fileBase) {
  catchError(buildResult: null, stageResult: null,
             message: "safeStashReport(${stashName}) failed; aggregation may be partial") {
    if (fileExists("${fileBase}.xml")) {
      stash name: stashName,
            includes: "${fileBase}.xml,${fileBase}.html",
            allowEmpty: false
    }
  }
}

void unstashIfPresent(String stashName) {
  try {
    unstash stashName
  } catch (Exception ignored) {
    echo "No stash '${stashName}' (board offline or stage failed before publishing)"
  }
}

// junit first (workspace-local, never flakes), then merge + archive.
void aggregateReports() {
  sh 'mkdir -p reports'
  cleanPreviousBuildFiles('reports')
  dir('reports') {
    expectedStashes().each { name -> unstashIfPresent(name) }
  }
  junit allowEmptyResults: true, testResults: 'reports/*.xml'
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'pytest_html_merger failed; per-stage HTMLs still archived') {
    sh './run-docker.sh pytest_html_merger -i reports/ -o reports/test_report_hw_final.html'
  }
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'archiveArtifacts (xml) failed') {
    archiveArtifacts artifacts: 'reports/*.xml', allowEmptyArchive: true
  }
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'archiveArtifacts (html) failed') {
    archiveArtifacts artifacts: 'reports/*.html', allowEmptyArchive: true
  }
}

void cleanPreviousBuildFiles(String buildDir) {
  if (buildDir && !buildDir.empty) {
    if (env.USER_CREDENTIALS) {
      sh "echo \$USER_CREDENTIALS_PSW | sudo -S rm -rf ${buildDir}*"
    } else {
      sh "rm -rf ${buildDir}"
    }
  }
}

void cleanUpWorkspaceOwnership() {
  if (env.USER_CREDENTIALS) {
    sh 'echo ${USER_CREDENTIALS_PSW} | sudo -S chown -R $(id -u):$(id -g) ${WORKSPACE}'
  }
}

void restartZynqPlatform() {
  if (env.USER_CREDENTIALS) {
    sh 'echo ${USER_CREDENTIALS_PSW} | sudo -S shutdown -r +1'
  }
}
