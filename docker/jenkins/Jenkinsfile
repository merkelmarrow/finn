import groovy.transform.Field

// ---------------------------------------------------------------------------
// Single source of truth for what runs in the Run Tests parallel block.
//
// Editing rule: if you want to add, remove, re-bucket or re-balance a stage,
// edit one of the tables below. Everything else (stage wiring, stash names,
// Check Stage Results aggregation) is generated from these tables.
// ---------------------------------------------------------------------------

// BNN end2end marker per board. Board names mirror test_board_map in
// tests/end2end/test_end2end_bnn_pynq.py; markers are defined in setup.cfg.
@Field
Map<String, String> BNN_BOARD_MARKERS = [
    'U250'     : 'bnn_u250',
    'Pynq-Z1'  : 'bnn_pynq',
    'ZCU104'   : 'bnn_zcu104',
    'KV260_SOM': 'bnn_kv260',
]

// BNN end2end sub-stages — one entry per (board, scenario-bucket).
//
// Why sub-stage at scenario granularity: on any given board cnv-w2a2 alone
// accounts for ~35-50 % of the BNN wall-clock (it scales super-linearly with
// precision because weight/activation bitwidth drives LUT/DSP count and
// Vivado impl's routing time). Isolating cnv-w2a2 on every board collapses
// the critical path from "sum of 9 scenarios on U250" to "one cnv-w2a2 on
// U250" and opens the door to per-scenario bitstream caching later.
//
// How to edit: add, remove, or re-bucket an entry. `-k` is a pytest
// keyword-expression that pytest matches as substrings against the
// parameterized test id. Test ids are produced by
// get_full_parameterized_test_list in tests/end2end/test_end2end_bnn_pynq.py
// with the format `<marker>_w<wbits>_a<abits>_<topology>_<board>`, e.g.
// `bnn_u250_w2_a2_cnv_U250`. There is no literal `w2a2` substring in the
// id (it is `w2_a2`), so an expression like `cnv and w2a2` matches zero
// tests and the stage exits with code 5. Always express bit-width as the
// pair `wN and aM` (or negated as `not (wN and aM)`).
//
// Worker counts: pytest -k that selects a single scenario sends all ~13
// test methods into one xdist_group, so only one worker actually executes;
// we use n=2 there (1 runs, 1 idle — cheap spare). Bucketed sub-stages that
// contain multiple scenarios benefit from n=4.
@Field
List<List<Object>> BNN_SUB_STAGES = [
    // board         label              -k expression                                n
    ['U250',         'cnv-w2a2',        'cnv and w2 and a2',                         2],
    ['U250',         'cnv-w2a1',        'cnv and w2 and a1',                         2],
    ['U250',         'cnv-w1a2',        'cnv and w1 and a2',                         2],
    ['U250',         'cnv-w1a1-tfc',    '(cnv and w1 and a1) or tfc',                4],
    ['U250',         'lfc',             'lfc',                                       2],
    ['ZCU104',       'cnv-heavy',       'cnv and w2',                                4],
    ['ZCU104',       'cnv-light-tfc',   '(cnv and w1) or tfc',                       4],
    ['ZCU104',       'lfc',             'lfc',                                       2],
    ['Pynq-Z1',      'cnv-w2a2',        'cnv and w2 and a2',                         2],
    ['Pynq-Z1',      'cnv-rest-tfc',    '(cnv and not (w2 and a2)) or tfc',          4],
    ['Pynq-Z1',      'lfc',             'lfc',                                       2],
    ['KV260_SOM',    'cnv-w2a2',        'cnv and w2 and a2',                         2],
    ['KV260_SOM',    'rest',            'not (cnv and w2 and a2)',                   4],
]

// End2end file shards. test_end2end_mobilenet_v1.py carries ~32 xdist_group
// marks and dominates the stage wall (~8 h of 20 h on #329); everything else
// fits into a single lighter shard.
@Field
List<String> END2END_MOBILENET = [
    'tests/end2end/test_end2end_mobilenet_v1.py',
]

@Field
List<String> END2END_REST = [
    'tests/end2end/test_end2end_bnn_pynq.py',
    'tests/end2end/test_end2end_cybsec_mlp.py',
    'tests/end2end/test_ext_weights.py',
    'tests/end2end/test_ooc_synthesis.py',
]

// fpgadataflow file shards. Starting split is round-robin on alphabetical
// order of the 47 test files under tests/fpgadataflow/, which bin-packs
// heavy tests (convinputgenerator, mvau, thresholding) across both shards
// in expectation. Rebalance after a real run by feeding
// tests/fpgadataflow/<junit>.xml to scripts/balance_fpgadataflow_shards.py
// and pasting its output over these two lists. Target: walls within ~15 %.
