    'tests/fpgadataflow/test_runtime_weights.py',
    'tests/fpgadataflow/test_split_large_fifos.py',
]

pipeline {
  agent none
  options {
    timeout(time: 72, unit: 'HOURS')
  }
  parameters {
    booleanParam(name: 'fpgadataflow', defaultValue: false, description: 'Run fpgadataflow tests')
    booleanParam(name: 'sanity', defaultValue: true, description: 'Run sanity hardware and unit tests')
    booleanParam(name: 'end2end', defaultValue: false, description: 'Run end2end tests')
  }
  stages {
    stage('Build Docker Image') {
      agent { label 'finn-build' }
      environment { FINN_DOCKER_PREBUILT = '0' }
      steps {
        script { buildAndPublishDockerImage() }
      }
    }
    stage('Run Tests') {
      steps { script { parallel(buildParallelStageMap()) } }
    }
    stage('Check Stage Results') {
      agent { label 'finn-build' }
      steps { script { aggregateReports() } }
    }
  }
}

void buildAndPublishDockerImage() {
  sh 'docker system prune -a -f'
  sh "./run-docker.sh echo 'Docker image build complete'"
  if (env.FINN_DOCKER_SHARED_DIR) {
    publishSharedDockerImage(env.FINN_DOCKER_SHARED_DIR)
  }
}

// Publish the built image to FINN_DOCKER_SHARED_DIR so other agents
// `docker load` it instead of rebuilding. Tag must match run-docker.sh.
void publishSharedDockerImage(String sharedDir) {
  def tag = sh(returnStdout: true, script:
      'echo "xilinx/finn:$(git describe --always --tags --dirty).${XRT_DEB_VERSION:-xrt_202220.2.14.354_22.04-amd64-xrt}"'
  ).trim()
  sh "mkdir -p ${sharedDir}"
  sh "echo '${tag}' > ${sharedDir}/finn-docker-tag.txt"
  // #!/bin/bash required: Jenkins durable-task defaults to /bin/sh (dash),
  // which lacks `set -o pipefail`.
  sh """#!/bin/bash
set -o pipefail
if command -v pigz >/dev/null 2>&1; then
  docker save '${tag}' | pigz -p \$(nproc) > '${sharedDir}/finn-docker-image.tar.gz'
else
  docker save '${tag}' | gzip > '${sharedDir}/finn-docker-image.tar.gz'
fi
"""
}

Map<String, Closure> buildParallelStageMap() {
  def branches = [:]
  if (params.sanity) {
    // Sanity-Build-Hardware rebuilds the same 4 scenarios the BNN sub-stages
    // already cover when end2end=true; skip it then to avoid redundant work.
    if (!params.end2end) {
      branches['Sanity - Build Hardware'] = { sanityBuildHardwareStage() }
    }
    branches['Sanity - Unit Tests'] = { sanityUnitTestsStage() }
  }
  if (params.fpgadataflow) {
    branches['fpgadataflow - shard A'] = { fpgadataflowShardStage('a', FPGADATAFLOW_SHARD_A, null) }
    branches['fpgadataflow - shard B'] = { fpgadataflowShardStage('b', ['tests/fpgadataflow/'], FPGADATAFLOW_SHARD_A) }
  }
  if (params.end2end) {
    END2END_SHARDS.each { entry ->
      branches["End2end - ${entry.label}"] = { end2endShardStage(entry) }
    }
    BNN_SUB_STAGES.each { entry ->
      branches["BNN ${entry.board} - ${entry.label}"] = { bnnSubStage(entry) }
    }
  }
  return branches
}

// Every parallel branch routes through testStage() so the report stash runs
// in `finally`; failed stages still publish their JUnit XML.

void sanityBuildHardwareStage() {
  testStage('Sanity - Build Hardware', 'bnn_build_sanity') { stashName, buildDir ->
    runPytest(marker: 'sanity_bnn', stash: stashName)
    BNN_BOARD_MARKERS.keySet().each { board ->
      findCopyZip(board, buildDir, stashName)
    }
  }
}

void sanityUnitTestsStage() {
  testStage('Sanity - Unit Tests', 'sanity_ut') { stashName, buildDir ->
    runPytest(
        marker: 'util or brevitas_export or streamline or transform or notebooks',
        stash: stashName,
        workers: defaultWorkers(),
        extraArgs: "--cov --cov-report=html:coverage_${stashName}",
    )
    archiveStageFolder("coverage_${stashName}")
  }
}

void fpgadataflowShardStage(String shardId, List<String> files, List<String> ignore) {
  String stashName = "fpgadataflow_${shardId}"
  testStage("fpgadataflow - shard ${shardId.toUpperCase()}", stashName) { name, buildDir ->
    runPytest(
        marker: 'fpgadataflow',
        stash: name,
        files: files,
        ignore: ignore,
        workers: defaultWorkers(),
        extraArgs: "--cov --cov-report=html:coverage_${name}",
    )
    archiveStageFolder("coverage_${name}")
  }
}

// --dist loadgroup is REQUIRED for end2end/BNN correctness — worksteal breaks
// the xdist_group / load_test_checkpoint_or_skip dependency chain and silently
// skips downstream tests.
void end2endShardStage(Map entry) {
  testStage("End2end - ${entry.label}", "end2end_${entry.label}") { stashName, buildDir ->
    runPytest(marker: 'end2end', stash: stashName, files: entry.files,
              workers: entry.workers as int, distMode: 'loadgroup')
  }
}

void bnnSubStage(Map entry) {
  String stashName = bnnStashName(entry)
  testStage("BNN ${entry.board} - ${entry.label}", stashName) { name, buildDir ->
    runPytest(
        marker: BNN_BOARD_MARKERS[entry.board],
        stash: name,
        keyword: entry.keyword,
        workers: entry.workers as int,
        distMode: 'loadgroup',
    )
    // Only cnv-w2a2 artefacts feed the board-HW validation job.
    if (entry.label == 'cnv-w2a2') {
      findCopyZip(entry.board, buildDir, name)
    }
  }
}

void testStage(String stageName, String stashName, Closure body) {
  node('finn-build') {
    stage(stageName) {
      checkout scm
      def buildDir = "${env.FINN_HOST_BUILD_DIR}/${stashName}"
      withEnv(["FINN_HOST_BUILD_DIR=${buildDir}"]) {
        sh "mkdir -p ${stashName}"
        cleanPreviousBuildFiles(buildDir)
        try {
          catchError(stageResult: 'FAILURE') {
            body.call(stashName, buildDir)
          }
        } finally {
          // MUST stay in `finally` so failed stages still publish their XML.
          safeStashReport(stashName)
        }
      }
    }
  }
}

// Stash <stash>.xml + <stash>.html iff pytest produced them. The defensive
// catchError ensures a stash hiccup cannot affect build status — pytest's
// own catchError already determines pass/fail.
void safeStashReport(String stashName) {
  catchError(buildResult: null, stageResult: null,
             message: "safeStashReport(${stashName}) failed; aggregation may be partial") {
    if (fileExists("${stashName}.xml")) {
      stash name: stashName, includes: "${stashName}.xml,${stashName}.html"
    }
  }
}

// Swallows "stash does not exist" when a stage was skipped or failed before
// publishing, so aggregation still sees every stash that did publish.
void unstashIfPresent(String stashName) {
  try {
    unstash stashName
  } catch (Exception ignored) {
    echo "No stash '${stashName}' (stage skipped or failed before publishing)"
  }
}

void archiveStageFolder(String folder) {
  catchError(buildResult: null, stageResult: null,
             message: "archiveArtifacts(${folder}) failed; non-fatal") {
    archiveArtifacts artifacts: "${folder}/**/*", allowEmptyArchive: true
  }
}

// Order is load-bearing: junit FIRST (workspace-local, never flakes), then
// the defensive merge + archive (agent->controller tar transfer can flake on
// glob counts > ~10). Reversing this loses the test tree on transfer flake.
void aggregateReports() {
  sh 'mkdir -p reports'
  cleanPreviousBuildFiles('reports')
  dir('reports') {
    expectedStashes().each { name -> unstashIfPresent(name) }
  }
  junit allowEmptyResults: true, testResults: 'reports/*.xml'
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'pytest_html_merger failed; per-stage HTMLs still archived') {
    sh './run-docker.sh pytest_html_merger -i reports/ -o reports/test_report_final.html'
  }
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'archiveArtifacts (xml) failed') {
    archiveArtifacts artifacts: 'reports/*.xml', allowEmptyArchive: true
  }
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'archiveArtifacts (html) failed') {
    archiveArtifacts artifacts: 'reports/*.html', allowEmptyArchive: true
  }
}

// Derived from the same tables the parallel block uses, so adding a sub-stage
// or flipping a param updates aggregation automatically.
List<String> expectedStashes() {
  def stashes = []
  if (params.sanity) {
    stashes << 'sanity_ut'
    if (!params.end2end) {
      stashes << 'bnn_build_sanity'
    }
  }
  if (params.fpgadataflow) {
    stashes += ['fpgadataflow_a', 'fpgadataflow_b']
  }
  if (params.end2end) {
    END2END_SHARDS.each { entry -> stashes << "end2end_${entry.label}" }
    BNN_SUB_STAGES.each { entry -> stashes << bnnStashName(entry) }
  }
  return stashes
}

// Stash names double as filesystem paths, so dashes become underscores.
String bnnStashName(Map entry) {
  return "bnn_${entry.board}_${entry.label}".replaceAll('-', '_')
}

void cleanPreviousBuildFiles(String buildDir) {
  if (buildDir && !buildDir.empty) {
    sh "rm -rf ${buildDir}"
  }
}

int defaultWorkers() {
  return (env.NUM_PYTEST_WORKERS ?: '8').toInteger()
}

// Single pytest entry point. Feeds the command line via a temporary script
// because run-docker.sh re-tokenises argv and a direct invocation would split
// quoted shell metacharacters in -m / -k expressions. Args (Map):
//   marker/stash      : required pytest -m and results filename stem
//   keyword/files/ignore : optional -k, explicit test paths, --ignore paths
//   workers/distMode  : optional xdist -n and --dist value
//   extraArgs         : free-form extra pytest args
void runPytest(Map opts) {
  def parts = ["python -m pytest -m '${opts.marker}'"]
  if (opts.files)   { parts << opts.files.join(' ') }
  if (opts.keyword) { parts << "-k '${opts.keyword}'" }
  (opts.ignore ?: []).each { parts << "--ignore=${it}" }
  if (opts.workers) {
    parts << "-n ${opts.workers} --dist ${opts.distMode ?: 'worksteal'}"
  }
  parts << "--junitxml=${opts.stash}.xml --html=${opts.stash}.html --self-contained-html"
  if (opts.extraArgs) { parts << opts.extraArgs }
  writeFile file: 'run-tests.sh', text: "#!/bin/bash\nset -eo pipefail\n${parts.join(' ')}\n"
  sh 'chmod 777 run-tests.sh'
  sh './run-docker.sh ./run-tests.sh'
}

void findCopyZip(String board, String findDir, String copyDir) {
  sh "mkdir -p ${copyDir}"
  try {
    sh "cp -r ${findDir}/hw_deployment_*/${board} ${copyDir}/"
    dir(copyDir) {
      sh "zip -r ${board}.zip ${board}/"
      sh "mkdir -p ${env.ARTIFACT_DIR}/${copyDir}/"
      sh "cp ${board}.zip ${env.ARTIFACT_DIR}/${copyDir}/"
    }
  } catch (err) {
    error "No ${board} hw_deployment_* build artifacts found in ${findDir}"
  }
}
