// Single source of truth for every parallel stage. One row per logical stage.
// Adding a row is the ONLY CI edit needed for a new marker/board. Shard count
// times workers determines wall-clock; the tests/conftest.py plugin does the
// actual hash-based split at pytest collection time. See docker/jenkins/README.md.

import groovy.transform.Field

// Per-board BNN rows — the single list that adding a new board requires
// editing. BNN_BOARDS and the per-board rows in PARALLEL_SHARDS are both
// derived from this so adding a board is a one-row change.
@Field
List<Map> BNN_BOARD_ROWS = [
    [stage: 'BNN U250',    marker: 'bnn_u250',    shards: 2, workers: 2, board: 'U250'],
    [stage: 'BNN Pynq-Z1', marker: 'bnn_pynq',    shards: 3, workers: 2, board: 'Pynq-Z1'],
    [stage: 'BNN ZCU104',  marker: 'bnn_zcu104',  shards: 2, workers: 4, board: 'ZCU104'],
    [stage: 'BNN KV260',   marker: 'bnn_kv260',   shards: 2, workers: 2, board: 'KV260_SOM'],
]

// Minimum free disk space (GB) required on each finn-build agent for a shard
// to start. Sized for ~2 concurrent fpgadataflow/bnn build trees on one agent
// (~60-80 GB each) plus headroom. Set 0 to disable (e.g. for --dry-run).
@Field
int FINN_CI_MIN_FREE_GB = 120

@Field
List<String> BNN_BOARDS = BNN_BOARD_ROWS.collect { it.board }

@Field
List<Map> PARALLEL_SHARDS = [
    // Sanity - Build Hardware rebuilds the same scenarios covered by the
    // bnn_* rows below, so skip it when end2end also runs.
    [param: 'sanity',       stage: 'Sanity - Build Hardware', marker: 'sanity_bnn',
     shards: 1, workers: 1, skipWhen: 'end2end', zipBoards: BNN_BOARDS],
    [param: 'sanity',       stage: 'Sanity - Unit Tests',     marker: 'util or brevitas_export or streamline or transform or notebooks',
     shards: 1, workers: 8, coverage: true],
    [param: 'fpgadataflow', stage: 'fpgadataflow',            marker: 'fpgadataflow',
     shards: 2, workers: 8, coverage: true],
    // iter-6: end2end has 3 xdist_groups (cybsec, ext_weights, mobilenet) and
    // mobilenet is the critical path (~705 min in #18). shards=3 lets the
    // round-robin-over-sorted-groups scheduler in conftest.py isolate mobilenet
    // on its own shard, leaving cybsec + ext_weights to finish quickly.
    [param: 'end2end',      stage: 'End2end',                 marker: 'end2end',
     shards: 3, workers: 6, distMode: 'loadgroup'],
] + BNN_BOARD_ROWS.collect { r ->
    // Per-board shard counts were rebalanced in iter-6 against observed .timings.json
    // from #18: over-sharded boards (U250 4->2, ZCU104 3->2) wasted wall-clock on
    // guard-skipped scenarios (wbits > abits) producing chain-break noise without
    // adding pass throughput. Group-aware sharding (conftest.py) keeps scenario
    // steps co-located so reducing shard count does not re-introduce chain breaks.
    [param: 'end2end', stage: r.stage, marker: r.marker,
     shards: r.shards, workers: r.workers, distMode: 'loadgroup',
     zipBoards: [r.board]]
}

// Marker expressions are interpolated into shell. Restrict to identifier
// characters + spaces so nothing can inject shell metacharacters.
@Field
java.util.regex.Pattern MARKER_SAFE_PATTERN = ~/^[A-Za-z0-9_ ]+$/

pipeline {
  agent none
  options {
    timeout(time: 72, unit: 'HOURS')
  }
  parameters {
    booleanParam(name: 'fpgadataflow', defaultValue: false, description: 'Run fpgadataflow tests')
    booleanParam(name: 'sanity',       defaultValue: true,  description: 'Run sanity hardware and unit tests')
    booleanParam(name: 'end2end',      defaultValue: false, description: 'Run end2end tests')
    string(name: 'STAGES', defaultValue: '',
           description: 'Substring filter on stage name (empty = all). Use to run one row for debugging.')
  }
  stages {
    stage('Validate') {
      agent { label 'finn-build' }
      steps { script { validateShards() } }
    }
    stage('Build Docker Image') {
      agent { label 'finn-build' }
      environment { FINN_DOCKER_PREBUILT = '0' }
      steps { script { buildAndPublishDockerImage() } }
    }
    stage('Run Tests') {
      steps { script { parallel(buildParallelStageMap()) } }
    }
    stage('Check Stage Results') {
      agent { label 'finn-build' }
      steps { script { aggregateReports() } }
    }
  }
}

// Return a job parameter via java.util.Map.get — `params` is a
// Collections$UnmodifiableMap, so standard Map access is sandbox-safe.
// (Earlier iter-5 draft used `params.getProperty(name)` under the mistaken
// assumption that `params[name]` was a sandbox hazard like `env[k]=v` from
// iter-1. `env` is EnvActionImpl, not a Map; `params` IS a Map, so
// DefaultGroovyMethods.getAt(Map,Object) applies and is whitelisted.
// `params.getProperty(name)` fails with MissingMethodException because
// UnmodifiableMap has no such method — verified on #16.)
boolean paramBool(String name) {
  def v = params.get(name)
  if (v == null) { return false }
  if (v instanceof Boolean) { return v }
  return v.toString().toBoolean()
}

String paramString(String name) {
  def v = params.get(name)
  return v == null ? '' : v.toString()
}

// Pre-flight: marker regex + executor budget. Marker violations are hard
// errors; budget overshoot is UNSTABLE because CI queues correctly anyway.
void validateShards() {
  PARALLEL_SHARDS.each { row ->
    if (!MARKER_SAFE_PATTERN.matcher(row.marker as String).matches()) {
      error "PARALLEL_SHARDS row '${row.stage}' has unsafe marker '${row.marker}' (only [A-Za-z0-9_ ] allowed)"
    }
    if (!(row.shards instanceof Integer) || (row.shards as int) < 1) {
      error "PARALLEL_SHARDS row '${row.stage}' has invalid shards=${row.shards}"
    }
  }
  // BNN_BOARDS must match the derived set from BNN_BOARD_ROWS (derived is the
  // source of truth; this asserts nobody hard-wired a stale value elsewhere).
  def derivedBnn = BNN_BOARD_ROWS.collect { it.board }
  if (BNN_BOARDS != derivedBnn) {
    error "BNN_BOARDS (${BNN_BOARDS}) drift from BNN_BOARD_ROWS (${derivedBnn})"
  }
  def activeCount = 0
  eachActiveShard { row, id -> activeCount++ }
  int available = 0
  try {
    def lbl = Jenkins.instance.getLabelAtom('finn-build')
    if (lbl) { available = lbl.getTotalExecutors() }
  } catch (Exception e) {
    echo "validateShards: executor query failed (${e.class.name}: ${e.message}); skipping budget check"
  }
  echo "validateShards: ${activeCount} shard(s) active; finn-build executors available: ${available}"
  if (available > 0 && activeCount > available) {
    unstable "PARALLEL_SHARDS requests ${activeCount} parallel shards but only ${available} finn-build executors are available; stages will queue and wall-clock will extend"
  }
}

void buildAndPublishDockerImage() {
  sh 'docker system prune -a -f'
  sh "./run-docker.sh echo 'Docker image build complete'"
  if (env.FINN_DOCKER_SHARED_DIR) {
    publishSharedDockerImage(env.FINN_DOCKER_SHARED_DIR)
  }
}

// Publish the built image to FINN_DOCKER_SHARED_DIR so other agents
// `docker load` it instead of rebuilding. Tag must match run-docker.sh.
void publishSharedDockerImage(String sharedDir) {
  def tag = sh(returnStdout: true, script:
      'echo "xilinx/finn:$(git describe --always --tags --dirty).${XRT_DEB_VERSION:-xrt_202220.2.14.354_22.04-amd64-xrt}"'
  ).trim()
  sh "mkdir -p ${sharedDir}"
  sh "echo '${tag}' > ${sharedDir}/finn-docker-tag.txt"
  // #!/bin/bash required: Jenkins durable-task defaults to /bin/sh (dash),
  // which lacks `set -o pipefail`.
  sh """#!/bin/bash
set -o pipefail
if command -v pigz >/dev/null 2>&1; then
  docker save '${tag}' | pigz -p \$(nproc) > '${sharedDir}/finn-docker-image.tar.gz'
else
  docker save '${tag}' | gzip > '${sharedDir}/finn-docker-image.tar.gz'
fi
"""
}

// Expand PARALLEL_SHARDS into (stage -> closure) pairs honouring param gates,
// skipWhen cross-param suppression, and the STAGES substring filter. Stash
// names are derived so adding a row does not require editing expectedStashes().
Map<String, Closure> buildParallelStageMap() {
  def branches = [:]
  eachActiveShard { row, id ->
    String stage = shardStageName(row, id)
    String stash = shardStashName(row, id)
    branches[stage] = { runShard(row, id, stage, stash) }
  }
  return branches
}

void eachActiveShard(Closure body) {
  String filter = paramString('STAGES')
  for (int rowIdx = 0; rowIdx < PARALLEL_SHARDS.size(); rowIdx++) {
    Map row = PARALLEL_SHARDS[rowIdx]
    if (!paramBool(row.param as String)) { continue }
    if (row.skipWhen && paramBool(row.skipWhen as String)) { continue }
    int numShards = row.shards as int
    // C-style for-loop (not `(0..<n).each`): groovy.lang.IntRange is not
    // Serializable, and when a range is a live local in the CPS frame that
    // reaches `parallel(...)`, every branch fails to persist with
    // NotSerializableException at the first checkpoint.
    for (int id = 0; id < numShards; id++) {
      String stage = shardStageName(row, id)
      if (filter && !stage.contains(filter)) { continue }
      body.call(row, id)
    }
  }
}

String shardStageName(Map row, int id) {
  return row.shards == 1 ? row.stage : "${row.stage} (${id + 1}/${row.shards})"
}

String shardStashName(Map row, int id) {
  String base = row.stage.toLowerCase().replaceAll(/[^a-z0-9]+/, '_').replaceAll(/^_|_$/, '')
  return row.shards == 1 ? base : "${base}_${id + 1}"
}

// The single parallel-stage body. Every row goes through here, so `stash` in
// `finally` and `junit`-first aggregation stay load-bearing for all shards.
void runShard(Map row, int shardIdx, String stageName, String stashName) {
  node('finn-build') {
    stage(stageName) {
      checkout scm
      // iter-6 A.1: prune legacy siblings under the parent tmp dir before we
      // remap FINN_HOST_BUILD_DIR to the per-shard path. Must run here so
      // `env.FINN_HOST_BUILD_DIR` still points at the shared parent.
      cleanStaleAgentDirs()
      def buildDir = "${env.FINN_HOST_BUILD_DIR}/${stashName}"
      withEnv(["FINN_HOST_BUILD_DIR=${buildDir}"]) {
        // iter-6 A.2: fail the shard fast if /scratch is below threshold
        // rather than letting pytest OOM-disk mid-run (5 such cascades in #18).
        checkAgentFreeSpace(FINN_CI_MIN_FREE_GB)
        sh "mkdir -p ${stashName}"
        cleanPreviousBuildFiles(buildDir)
        try {
          catchError(stageResult: 'FAILURE') {
            Map opts = [
                marker: row.marker,
                stash: stashName,
                workers: row.workers as int,
                distMode: row.distMode,
            ]
            if ((row.shards as int) > 1) {
              opts.numShards = row.shards as int
              opts.shardId = shardIdx
            } else {
              // Even unsharded rows emit timings via --num-shards=1 so the
              // observability path is uniform. conftest.py treats --num-shards=1
              // as a no-op for sharding but still writes <stash>.timings.json.
              opts.numShards = 1
              opts.shardId = 0
            }
            if (row.coverage) {
              opts.extraArgs = "--cov --cov-report=html:coverage_${stashName}"
            }
            runPytest(opts)
            if (row.coverage) { archiveStageFolder("coverage_${stashName}") }
            (row.zipBoards ?: []).each { board ->
              findCopyZip(board, buildDir, stashName)
            }
          }
        } finally {
          // MUST stay in `finally` so failed stages still publish their XML.
          safeStashReport(stashName)
        }
      }
    }
  }
}

// Stash <stash>.xml + <stash>.html + <stash>.timings.json iff pytest produced
// them. The defensive catchError ensures a stash hiccup cannot affect build
// status — pytest's own catchError already determines pass/fail.
void safeStashReport(String stashName) {
  catchError(buildResult: null, stageResult: null,
             message: "safeStashReport(${stashName}) failed; aggregation may be partial") {
    if (fileExists("${stashName}.xml")) {
      stash name: stashName,
            includes: "${stashName}.xml,${stashName}.html,${stashName}.timings.json",
            allowEmpty: false
    }
  }
}

// Swallows "stash does not exist" when a stage was skipped or failed before
// publishing, so aggregation still sees every stash that did publish.
void unstashIfPresent(String stashName) {
  try {
    unstash stashName
  } catch (Exception ignored) {
    echo "No stash '${stashName}' (stage skipped or failed before publishing)"
  }
}

void archiveStageFolder(String folder) {
  catchError(buildResult: null, stageResult: null,
             message: "archiveArtifacts(${folder}) failed; non-fatal") {
    archiveArtifacts artifacts: "${folder}/**/*", allowEmptyArchive: true
  }
}

// Order is load-bearing: junit FIRST (workspace-local, never flakes), then
// the defensive merge + archive (agent->controller tar transfer can flake on
// glob counts > ~10). Reversing this loses the test tree on transfer flake.
void aggregateReports() {
  sh 'mkdir -p reports'
  cleanPreviousBuildFiles('reports')
  dir('reports') {
    expectedStashes().each { name -> unstashIfPresent(name) }
  }
  junit allowEmptyResults: true, testResults: 'reports/*.xml'
  echoShardTimings()
  assertZipBoardsEmitted()
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'pytest_html_merger failed; per-stage HTMLs still archived') {
    sh './run-docker.sh pytest_html_merger -i reports/ -o reports/test_report_final.html'
  }
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'archiveArtifacts (xml) failed') {
    archiveArtifacts artifacts: 'reports/*.xml', allowEmptyArchive: true
  }
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'archiveArtifacts (html) failed') {
    archiveArtifacts artifacts: 'reports/*.html', allowEmptyArchive: true
  }
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'archiveArtifacts (timings.json) failed') {
    archiveArtifacts artifacts: 'reports/*.timings.json', allowEmptyArchive: true
  }
}

// Per-shard wall-clock summary. Reads reports/*.timings.json (emitted by the
// conftest plugin) and groups by marker family (stripped trailing _N). Warns
// when any shard is > 1.5x the median wall-clock for its family.
void echoShardTimings() {
  catchError(buildResult: null, stageResult: null,
             message: 'echoShardTimings failed; non-fatal') {
    if (!fileExists('reports')) { return }
    def count = sh(returnStdout: true, script:
        "find reports -maxdepth 1 -type f -name '*.timings.json' | wc -l").trim()
    if (count == '0') {
      echo 'echoShardTimings: no timings.json found; skipping summary'
      return
    }
    sh '''#!/bin/bash
set -eo pipefail
python3 - <<'PY'
import glob, json, os, re, collections
rows = []
for p in sorted(glob.glob("reports/*.timings.json")):
    try:
        with open(p) as f:
            d = json.load(f)
    except Exception as e:
        print("!! could not parse %s: %s" % (p, e))
        continue
    stash = d.get("stash") or os.path.basename(p).split(".")[0]
    groups = d.get("groups") or []
    top = groups[0] if groups else {"name": "(none)", "seconds": 0.0}
    rows.append((stash, int(d.get("shard", {}).get("id", 0)),
                 float(d.get("wall_seconds", 0.0)),
                 float(top.get("seconds", 0.0)), str(top.get("name", ""))))
if not rows:
    print("echoShardTimings: no parseable timings.json files")
    raise SystemExit(0)

def family(s):
    return re.sub(r"_\\d+$", "", s)

by_family = collections.defaultdict(list)
for r in rows:
    by_family[family(r[0])].append(r)

print()
print("=== per-shard wall-clock ===")
print("%-36s %3s %10s %12s  %s" % ("stash", "id", "wall_s", "max_group_s", "max_group"))
print("-" * 100)
unstable_found = False
for fam in sorted(by_family):
    rs = sorted(by_family[fam], key=lambda r: r[1])
    walls = sorted(r[2] for r in rs)
    median = walls[len(walls)//2] if walls else 0.0
    for (stash, sid, wall, mx_sec, mx_name) in rs:
        flag = ""
        if median > 0.0 and wall > 1.5 * median:
            flag = "  <<< SLOW SHARD (%.1fx median)" % (wall / median)
            unstable_found = True
        print("%-36s %3d %10.1f %12.1f  %s%s" % (stash, sid, wall, mx_sec, mx_name, flag))
    print()
if unstable_found:
    print("echoShardTimings: one or more shards are > 1.5x family median; "
          "consider rebalancing `shards:` in PARALLEL_SHARDS")
PY
'''
  }
}

// Post-condition: every active row declaring zipBoards must have produced a
// <board>.zip in ARTIFACT_DIR for each board. Missing zips mean no shard ran
// the bitstream-emitting scenario — a silent-skip class the pre-shard coverage
// guard doesn't catch (marker has items, but the specific parametrisation
// that emits bitstreams isn't in any of them). UNSTABLE, not FAILURE, because
// the upstream cause (marker typo, test filter) would surface via junit too.
void assertZipBoardsEmitted() {
  catchError(buildResult: null, stageResult: null,
             message: 'assertZipBoardsEmitted failed; non-fatal') {
    def missing = []
    eachActiveShard { row, id ->
      if (!row.zipBoards) { return }
      if (id != 0) { return }  // check once per row, not once per shard
      String stash = shardStashName(row, id)
      (row.zipBoards ?: []).each { board ->
        String expected = "${env.ARTIFACT_DIR}/${stash}/${board}.zip"
        if (!fileExists(expected)) {
          missing << "${row.stage} -> ${board} (expected ${expected})"
        }
      }
    }
    if (!missing.isEmpty()) {
      echo "assertZipBoardsEmitted: missing ${missing.size()} expected board zip(s):\n  - " + missing.join('\n  - ')
      unstable "assertZipBoardsEmitted: ${missing.size()} expected board zip(s) missing (see log above); no shard emitted the bitstream-producing scenario"
    }
  }
}

// Derived from PARALLEL_SHARDS so a new row is auto-included in aggregation.
List<String> expectedStashes() {
  def stashes = []
  eachActiveShard { row, id -> stashes << shardStashName(row, id) }
  return stashes
}

// iter-6 C: clean buildDir on the host AND pre-create it so docker's `-v`
// mount finds an existing source and doesn't auto-create the bind parent as
// root:root (which the in-container cse-jenkins user can't then write to,
// observed as PermissionError on end2end tests in #21). The existence check
// after rm fails loud if a previous container left root-owned residue that
// this shard can't clean — the operator needs to nuke it with sudo once.
void cleanPreviousBuildFiles(String buildDir) {
  if (!buildDir || buildDir.empty) { return }
  sh """
    rm -rf '${buildDir}' 2>/dev/null || true
    if [ -d '${buildDir}' ]; then
      echo "cleanPreviousBuildFiles: '${buildDir}' still exists after rm; likely root-owned residue from a previous container. Ask an admin to 'sudo rm -rf ${buildDir}' on this agent. Contents:"
      ls -la '${buildDir}' | head -40
      exit 1
    fi
    mkdir -p '${buildDir}'
  """
}

// iter-6 A.1: prune directories in FINN_HOST_BUILD_DIR that aren't an
// expected stash for this build. Safe across concurrent shards because the
// whitelist is identical in every shard, so no two shards ever disagree on
// which sibling is stale. In-progress siblings are whitelisted, so this
// never races with a live build. Only touches immediate children, never
// recurses into files we don't own.
void cleanStaleAgentDirs() {
  if (!env.FINN_HOST_BUILD_DIR) { return }
  def expected = new HashSet(expectedStashes())
  def listing = sh(returnStdout: true, script:
      "ls -1A '${env.FINN_HOST_BUILD_DIR}' 2>/dev/null || true"
  ).trim()
  if (!listing) { return }
  // readLines() returns an ArrayList<String>; split('\n') returns String[]
  // whose iterator is org.codehaus.groovy.util.ArrayIterator, which is not
  // serializable and fails the CPS checkpoint on the sh inside .each below
  // (same class of bug as the IntRange fix in iter-5).
  def stale = listing.readLines().findAll { it && !expected.contains(it) }
  if (stale.isEmpty()) { return }
  echo "cleanStaleAgentDirs: pruning ${stale.size()} non-whitelisted entry/entries in ${env.FINN_HOST_BUILD_DIR}: ${stale}"
  stale.each { name ->
    catchError(buildResult: null, stageResult: null,
               message: "could not remove stale '${name}'; non-fatal") {
      sh "rm -rf '${env.FINN_HOST_BUILD_DIR}/${name}'"
    }
  }
}

// iter-6 A.2: fail the shard fast if the agent's scratch is below threshold.
// Prevents the mid-pytest OSError-28 cascade observed on xircseeng01 in #18.
void checkAgentFreeSpace(int minFreeGB) {
  if (minFreeGB <= 0) { return }
  String target = env.FINN_HOST_BUILD_DIR ?: '/scratch'
  // The shard's own dir doesn't exist yet (mkdir happens later in runShard),
  // so climb up to the nearest existing ancestor before calling df. Without
  // this, df emits a single "No such file or directory" line, awk returns
  // empty, and the parser falls back to 0 -> every shard aborts (#19).
  def raw = sh(returnStdout: true, script: """
d='${target}'
while [ ! -d "\$d" ] && [ "\$d" != '/' ]; do d=\$(dirname "\$d"); done
df -BG "\$d" | awk 'NR==2 {print \$4}' | tr -d 'G'
""").trim()
  int freeGB = raw.isInteger() ? raw.toInteger() : -1
  echo "checkAgentFreeSpace[${env.NODE_NAME}]: ${freeGB} GB free (probed ${target}; threshold ${minFreeGB} GB)"
  if (freeGB < 0) {
    echo "checkAgentFreeSpace[${env.NODE_NAME}]: could not parse df output (${raw.take(80)}); skipping precheck"
    return
  }
  if (freeGB < minFreeGB) {
    error "agent ${env.NODE_NAME} has only ${freeGB} GB free on ${target} (< ${minFreeGB} GB threshold); aborting shard to avoid mid-run disk exhaustion. Free space by pruning /scratch or reduce concurrent shards on this agent (see jenkins_ci.md iter-6)."
  }
}

// Single pytest entry point. Feeds the command line via a temporary script
// because run-docker.sh re-tokenises argv and would split quoted metacharacters
// in `-m` expressions otherwise. Marker expression is passed via an env var
// rather than single-quote interpolation so shell metachars in a (malformed)
// marker value can't escape — validateShards() already rejects those, this is
// defence in depth. Args (Map): marker/stash required; workers, distMode,
// numShards/shardId, extraArgs optional.
void runPytest(Map opts) {
  def parts = ["python -m pytest -m \"\$FINN_CI_MARKER\""]
  if (opts.workers) {
    parts << "-n ${opts.workers} --dist ${opts.distMode ?: 'worksteal'}"
  }
  if (opts.numShards) {
    parts << "--num-shards ${opts.numShards} --shard-id ${opts.shardId}"
  }
  parts << "--junitxml=${opts.stash}.xml --html=${opts.stash}.html --self-contained-html"
  if (opts.extraArgs) { parts << opts.extraArgs }
  def cmd = parts.join(' ')
  echo "runPytest[${opts.stash}]: FINN_CI_MARKER='${opts.marker}'; ${cmd}"
  // pytest exit 5 = "no tests collected". With hash-sharding this happens
  // legitimately when an over-provisioned shard count leaves one shard empty;
  // pre-shard-empty is already caught loudly by the plugin in tests/conftest.py,
  // so exit 5 here is a "reduce shards: in PARALLEL_SHARDS" hint, not a failure.
  writeFile file: 'run-tests.sh', text:
      "#!/bin/bash\nset -o pipefail\nexport FINN_CI_MARKER='${opts.marker}'\n${cmd}\nec=\$?\n[ \$ec -eq 5 ] && exit 0 || exit \$ec\n"
  sh 'chmod 777 run-tests.sh'
  sh './run-docker.sh ./run-tests.sh'
}

// Silent no-op if the board's hw_deployment_* directory is absent: with hash
// sharding, only the shard that happened to run cnv-w2a2 produces artefacts.
// The zipBoards postcondition in aggregateReports catches the case where NO
// shard produced the expected artefact.
void findCopyZip(String board, String findDir, String copyDir) {
  if (!fileExists("${findDir}")) { return }
  def found = sh(returnStdout: true, script:
      "find ${findDir} -maxdepth 2 -type d -name '${board}' -path '*/hw_deployment_*/*' | head -1"
  ).trim()
  if (!found) { return }
  sh "mkdir -p ${copyDir}"
  sh "cp -r ${found} ${copyDir}/"
  dir(copyDir) {
    sh "zip -r ${board}.zip ${board}/"
    sh "mkdir -p ${env.ARTIFACT_DIR}/${copyDir}/"
    sh "cp ${board}.zip ${env.ARTIFACT_DIR}/${copyDir}/"
  }
}
