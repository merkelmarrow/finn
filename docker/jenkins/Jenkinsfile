// Shard config in tests/ci_shards.py is the single source of truth shared
// with pytest. See docker/jenkins/README.md.

import groovy.transform.Field

@Field
List<Map> PARALLEL_SHARDS = []

// Sized for ~2 concurrent build trees per agent (~60-80 GB each) plus headroom.
@Field
int FINN_CI_MIN_FREE_GB = 120

@Field
int FINN_CI_TMP_RETAIN_BUILDS = 5

@Field
int FINN_CI_TMP_MAX_AGE_DAYS = 14

void loadStageConfig() {
  String json = sh(returnStdout: true, script:
    "python3 -c 'import json, sys; sys.path.insert(0, \"tests\"); " +
    "from ci_shards import STAGES; print(json.dumps(STAGES))'"
  ).trim()
  PARALLEL_SHARDS = readJSON(text: json).collect { it as Map }
}

// Marker is interpolated into a shell command, so reject anything that could escape it.
@Field
java.util.regex.Pattern MARKER_SAFE_PATTERN = ~/^[A-Za-z0-9_ ]+$/

pipeline {
  agent none
  options {
    timeout(time: 72, unit: 'HOURS')
  }
  parameters {
    booleanParam(name: 'fpgadataflow', defaultValue: false, description: 'Run fpgadataflow tests')
    booleanParam(name: 'sanity',       defaultValue: true,  description: 'Run sanity hardware and unit tests')
    booleanParam(name: 'end2end',      defaultValue: false, description: 'Run end2end tests')
    string(name: 'STAGES', defaultValue: '',
           description: 'Substring filter on stage name (empty = all). Use to run one row for debugging.')
  }
  stages {
    // Funnel per-agent config through withAgentNfsEnv so adding a finn-build
    // host is a jenkins_slaves.yml edit only, never a Jenkinsfile edit.
    stage('Validate') {
      agent { label 'finn-build' }
      steps { script { wipeStaleWorkspace(); withAgentNfsEnv { loadStageConfig(); validateShards(); rotateFinnCiBuildTmp() } } }
    }
    stage('Build Docker Image') {
      agent { label 'finn-build' }
      environment { FINN_DOCKER_PREBUILT = '0' }
      steps { script { wipeStaleWorkspace(); withAgentNfsEnv { buildAndPublishDockerImage() } } }
    }
    stage('Run Tests') {
      steps { script { parallel(buildParallelStageMap()) } }
    }
    stage('Check Stage Results') {
      agent { label 'finn-build' }
      steps { script { withAgentNfsEnv { aggregateReports() } } }
    }
  }
}

// params is an UnmodifiableMap, so use Map.get (sandbox-safe) not getProperty.
boolean paramBool(String name) {
  def v = params.get(name)
  if (v == null) { return false }
  if (v instanceof Boolean) { return v }
  return v.toString().toBoolean()
}

String paramString(String name) {
  def v = params.get(name)
  return v == null ? '' : v.toString()
}

// Marker violations are hard errors. Over-subscribing executors only warns
// because queueing is recoverable, just slow.
void validateShards() {
  if (!PARALLEL_SHARDS) {
    error "PARALLEL_SHARDS is empty; loadStageConfig() must run before validateShards()"
  }
  PARALLEL_SHARDS.each { row ->
    if (!MARKER_SAFE_PATTERN.matcher(row.marker as String).matches()) {
      error "PARALLEL_SHARDS row '${row.stage}' has unsafe marker '${row.marker}' (only [A-Za-z0-9_ ] allowed)"
    }
    if (!(row.shards instanceof Integer) || (row.shards as int) < 1) {
      error "PARALLEL_SHARDS row '${row.stage}' has invalid shards=${row.shards}"
    }
  }
  def activeCount = 0
  eachActiveShard { row, id -> activeCount++ }
  int available = 0
  try {
    def lbl = Jenkins.instance.getLabelAtom('finn-build')
    if (lbl) { available = lbl.getTotalExecutors() }
  } catch (Exception e) {
    echo "validateShards: executor query failed (${e.class.name}: ${e.message}); skipping budget check"
  }
  echo "validateShards: ${activeCount} shard(s) active; finn-build executors available: ${available}"
  if (available > 0 && activeCount > available) {
    unstable "PARALLEL_SHARDS requests ${activeCount} parallel shards but only ${available} finn-build executors are available; stages will queue and wall-clock will extend"
  }
}

void buildAndPublishDockerImage() {
  sh 'docker system prune -a -f'
  sh "./run-docker.sh echo 'Docker image build complete'"
  if (env.FINN_DOCKER_SHARED_DIR) {
    publishSharedDockerImage(env.FINN_DOCKER_SHARED_DIR)
  }
}

// Other agents docker load from FINN_DOCKER_SHARED_DIR instead of rebuilding.
// Tag must match run-docker.sh.
void publishSharedDockerImage(String sharedDir) {
  def tag = sh(returnStdout: true, script:
      'echo "xilinx/finn:$(git describe --always --tags --dirty).${XRT_DEB_VERSION:-xrt_202220.2.14.354_22.04-amd64-xrt}"'
  ).trim()
  sh "mkdir -p ${sharedDir}"
  sh "echo '${tag}' > ${sharedDir}/finn-docker-tag.txt"
  // bash for set -o pipefail because Jenkins defaults sh to dash.
  sh """#!/bin/bash
set -o pipefail
if command -v pigz >/dev/null 2>&1; then
  docker save '${tag}' | pigz -p \$(nproc) > '${sharedDir}/finn-docker-image.tar.gz'
else
  docker save '${tag}' | gzip > '${sharedDir}/finn-docker-image.tar.gz'
fi
"""
}

Map<String, Closure> buildParallelStageMap() {
  def branches = [:]
  eachActiveShard { row, id ->
    String stage = shardStageName(row, id)
    String stash = shardStashName(row, id)
    branches[stage] = { runShard(row, id, stage, stash) }
  }
  return branches
}

void eachActiveShard(Closure body) {
  String filter = paramString('STAGES')
  for (int rowIdx = 0; rowIdx < PARALLEL_SHARDS.size(); rowIdx++) {
    Map row = PARALLEL_SHARDS[rowIdx]
    if (!paramBool(row.param as String)) { continue }
    if (row.skipWhen && paramBool(row.skipWhen as String)) { continue }
    int numShards = row.shards as int
    // C-style for-loop because groovy.lang.IntRange is not Serializable and
    // breaks CPS persistence when it survives into parallel(...).
    for (int id = 0; id < numShards; id++) {
      String stage = shardStageName(row, id)
      if (filter && !stage.contains(filter)) { continue }
      body.call(row, id)
    }
  }
}

String shardStageName(Map row, int id) {
  return row.shards == 1 ? row.stage : "${row.stage} (${id + 1}/${row.shards})"
}

String shardStashName(Map row, int id) {
  String base = row.stage.toLowerCase().replaceAll(/[^a-z0-9]+/, '_').replaceAll(/^_|_$/, '')
  return row.shards == 1 ? base : "${base}_${id + 1}"
}

// jobKey under ci_runs/ keeps two jobs that happen to share a build number
// on the same host from colliding.
String finnCiJobKey() {
  String jn = env.JOB_NAME ?: 'job'
  return jn.replaceAll('[^A-Za-z0-9._-]+', '_')
}

// Build trees are keyed on job/build so concurrent runs do not stomp on each
// other. The shared NFS root makes them visible across agents when set,
// otherwise the path is workspace-local but still build-keyed.
String finnCiPerBuildRoot() {
  if (!env.BUILD_NUMBER) { error "BUILD_NUMBER is unset" }
  String r = env.FINN_AGENT_NFS_ROOT
  if (r) {
    return "${r}/workspace/tmp/ci_runs/${finnCiJobKey()}/${env.BUILD_NUMBER}"
  }
  String ws = env.WORKSPACE
  if (!ws) { error "WORKSPACE is unset; cannot derive a build root without FINN_AGENT_NFS_ROOT" }
  return "${ws}/tmp/ci_runs/${env.BUILD_NUMBER}"
}

// Bound disk usage on the shared NFS root once per build. No-op when local.
void rotateFinnCiBuildTmp() {
  String root = env.FINN_AGENT_NFS_ROOT
  if (!root) { return }
  String jk = finnCiJobKey()
  String bn = env.BUILD_NUMBER
  String ws = env.WORKSPACE
  if (!ws) { echo "rotateFinnCiBuildTmp: WORKSPACE unset, skipping"; return }
  sh """
    bash "${ws}/scripts/rotate_finn_ci_tmp.sh" "${root}" "${jk}" "${bn}" ${FINN_CI_TMP_RETAIN_BUILDS} ${FINN_CI_TMP_MAX_AGE_DAYS}
  """
}

// Must run after node binding because ${NODE_NAME} resolves in Groovy and
// run-docker.sh does not re-expand vars embedded in FINN_DOCKER_EXTRA. The
// hostname pin is unconditional: bsub's gethostbyname() on the default
// finn_dev_<user> hostname fails LSF submission with "Error 0", and that
// is independent of whether the agent has FINN_AGENT_NFS_ROOT set.
void withAgentNfsEnv(Closure body) {
  String agentNfsRoot = env.FINN_AGENT_NFS_ROOT
  String dockerExtra = "${env.FINN_DOCKER_EXTRA ?: ''} --hostname ${env.NODE_NAME}"
  if (!agentNfsRoot) {
    withEnv(["FINN_DOCKER_EXTRA=${dockerExtra}"]) { body() }
    return
  }
  withEnv([
    "FINN_HOST_BUILD_DIR=${agentNfsRoot}/workspace/tmp",
    "FINN_XRT_PATH=${agentNfsRoot}/caches/xrt",
    "FINN_DOCKER_CACHE_DIR=${agentNfsRoot}/caches/finn_cache",
    "FINN_DOCKER_EXTRA=${dockerExtra} " +
      "-v ${agentNfsRoot}/caches/vivado_ip_cache:/tmp/vivado_ip_cache",
  ]) { body() }
}

// Cold start every shard so stale outputs cannot mask ordering bugs or
// dep regressions in a reused workspace.
void wipeStaleWorkspace() {
  sh 'git clean -ffdx'
}

// finally is load-bearing so failed stages still publish their JUnit XML.
void runShard(Map row, int shardIdx, String stageName, String stashName) {
  node('finn-build') {
    withAgentNfsEnv {
    stage(stageName) {
      checkout scm
      wipeStaleWorkspace()
      String perBuildRoot = finnCiPerBuildRoot()
      def buildDir = "${perBuildRoot}/${stashName}"
      String stageMap = "[stage-map] build=${env.BUILD_NUMBER} stage='${stageName}' stash=${stashName} shard=${shardIdx + 1}/${row.shards} node=${env.NODE_NAME} workspace=${env.WORKSPACE} build_dir=${buildDir}"
      echo stageMap
      writeFile file: "${stashName}.stagemap", text: "${stageMap}\n"
      withEnv(["FINN_HOST_BUILD_DIR=${buildDir}"]) {
        sh "mkdir -p '${perBuildRoot}'"
        checkAgentFreeSpace(FINN_CI_MIN_FREE_GB)
        sh "mkdir -p ${stashName}"
        cleanPreviousBuildFiles(buildDir)
        try {
          catchError(stageResult: 'FAILURE') {
            Map opts = [
                marker: row.marker,
                stash: stashName,
                workers: row.workers as int,
                distMode: row.distMode,
                numShards: row.shards as int,
                shardId: shardIdx,
            ]
            if (row.coverage) {
              opts.extraArgs = "--cov --cov-report=html:coverage_${stashName}"
            }
            runPytest(opts)
            if (row.coverage) { archiveStageFolder("coverage_${stashName}") }
            (row.zipBoards ?: []).each { board ->
              findCopyZip(board, buildDir, stashName)
            }
          }
        } finally {
          safeStashReport(stashName)
        }
      }
    }
    }
  }
}

// catchError keeps a stash hiccup from masking pytest's own pass/fail.
void safeStashReport(String stashName) {
  catchError(buildResult: null, stageResult: null,
             message: "safeStashReport(${stashName}) failed; aggregation may be partial") {
    stash name: stashName,
          includes: "${stashName}.xml,${stashName}.html,${stashName}.timings.json,${stashName}.stagemap",
          allowEmpty: true
  }
}

// Swallowing the missing-stash exception lets aggregation still see the rest.
void unstashIfPresent(String stashName) {
  try {
    unstash stashName
  } catch (Exception ignored) {
    echo "No stash '${stashName}' (stage skipped or failed before publishing)"
  }
}

void archiveStageFolder(String folder) {
  catchError(buildResult: null, stageResult: null,
             message: "archiveArtifacts(${folder}) failed; non-fatal") {
    archiveArtifacts artifacts: "${folder}/**/*", allowEmptyArchive: true
  }
}

// junit first because it is workspace-local and never flakes. The merge and
// archive steps come after because agent-to-controller tar transfer can
// flake on large globs and we still want JUnit reported.
void aggregateReports() {
  sh 'mkdir -p reports'
  cleanPreviousBuildFiles('reports')
  dir('reports') {
    expectedStashes().each { name -> unstashIfPresent(name) }
  }
  junit allowEmptyResults: true, testResults: 'reports/*.xml'
  echoShardTimings()
  publishStageMap()
  assertZipBoardsEmitted()
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'pytest_html_merger failed; per-stage HTMLs still archived') {
    sh './run-docker.sh pytest_html_merger -i reports/ -o reports/test_report_final.html'
  }
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'archiveArtifacts (xml) failed') {
    archiveArtifacts artifacts: 'reports/*.xml', allowEmptyArchive: true
  }
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'archiveArtifacts (html) failed') {
    archiveArtifacts artifacts: 'reports/*.html', allowEmptyArchive: true
  }
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'archiveArtifacts (timings.json) failed') {
    archiveArtifacts artifacts: 'reports/*.timings.json', allowEmptyArchive: true
  }
}

void publishStageMap() {
  catchError(buildResult: null, stageResult: null,
             message: 'publishStageMap failed; non-fatal') {
    if (!fileExists('reports')) { return }
    sh "cat reports/*.stagemap 2>/dev/null | sort > reports/stage_map.txt || true"
    if (!fileExists('reports/stage_map.txt')) { return }
    archiveArtifacts artifacts: 'reports/stage_map.txt', allowEmptyArchive: true
    String body = readFile('reports/stage_map.txt').trim()
    if (body) {
      currentBuild.description = body
    }
  }
}

// Warns when a shard exceeds 1.5x its family median wall clock.
void echoShardTimings() {
  catchError(buildResult: null, stageResult: null,
             message: 'echoShardTimings failed; non-fatal') {
    if (!fileExists('reports')) { return }
    sh "python3 scripts/summarize_ci_timings.py reports/"
  }
}

// Catches the case where a row declared zipBoards but no shard wrote the zip.
void assertZipBoardsEmitted() {
  catchError(buildResult: null, stageResult: null,
             message: 'assertZipBoardsEmitted failed; non-fatal') {
    def missing = []
    eachActiveShard { row, id ->
      if (!row.zipBoards || id != 0) { return }
      String stash = shardStashName(row, id)
      (row.zipBoards ?: []).each { board ->
        String expected = "${env.ARTIFACT_DIR}/${stash}/${board}.zip"
        if (!fileExists(expected)) {
          missing << "${row.stage} -> ${board} (expected ${expected})"
        }
      }
    }
    if (!missing.isEmpty()) {
      echo "assertZipBoardsEmitted: missing ${missing.size()} expected board zip(s):\n  - " + missing.join('\n  - ')
      unstable "assertZipBoardsEmitted: ${missing.size()} expected board zip(s) missing"
    }
  }
}

// Derived from PARALLEL_SHARDS so adding a new row auto-includes it here.
List<String> expectedStashes() {
  def stashes = []
  eachActiveShard { row, id -> stashes << shardStashName(row, id) }
  return stashes
}

// Pre-create buildDir as the unprivileged user. Otherwise docker's -v mount
// auto-creates the bind parent as root:root and the in-container user cannot
// write to it. Hard-fail on root-owned residue so an operator can sudo rm it.
void cleanPreviousBuildFiles(String buildDir) {
  if (!buildDir || buildDir.empty) { return }
  sh """
    rm -rf '${buildDir}' 2>/dev/null || true
    if [ -d '${buildDir}' ]; then
      echo "cleanPreviousBuildFiles: '${buildDir}' still exists after rm; likely root-owned residue. Ask an admin to 'sudo rm -rf ${buildDir}' on this agent."
      ls -la '${buildDir}' | head -40
      exit 1
    fi
    mkdir -p '${buildDir}'
  """
}

// Fail fast on low scratch space so pytest does not hit ENOSPC mid-run.
void checkAgentFreeSpace(int minFreeGB) {
  if (minFreeGB <= 0) { return }
  String target = env.FINN_HOST_BUILD_DIR ?: '/scratch'
  // Climb to the nearest existing ancestor because df on a missing path
  // returns empty and the shard's own dir is not yet mkdir'd.
  def raw = sh(returnStdout: true, script: """
d='${target}'
while [ ! -d "\$d" ] && [ "\$d" != '/' ]; do d=\$(dirname "\$d"); done
df -BG "\$d" | awk 'NR==2 {print \$4}' | tr -d 'G'
""").trim()
  int freeGB = raw.isInteger() ? raw.toInteger() : -1
  echo "checkAgentFreeSpace[${env.NODE_NAME}]: ${freeGB} GB free (probed ${target}; threshold ${minFreeGB} GB)"
  if (freeGB < 0) {
    echo "checkAgentFreeSpace[${env.NODE_NAME}]: could not parse df output (${raw.take(80)}); skipping precheck"
    return
  }
  if (freeGB < minFreeGB) {
    error "agent ${env.NODE_NAME} has only ${freeGB} GB free on ${target} (< ${minFreeGB} GB threshold); aborting shard to avoid mid-run disk exhaustion."
  }
}

// Marker travels via env var so a malformed value cannot escape into the
// shell, and the wrapper script keeps run-docker.sh from re-tokenising the
// -m "..." argv. Exit 5 (no tests collected) maps to success because the
// conftest plugin already loud-fails empty collection separately.
void runPytest(Map opts) {
  def parts = ["python -m pytest -m \"\$FINN_CI_MARKER\""]
  if (opts.workers) {
    parts << "-n ${opts.workers} --dist ${opts.distMode ?: 'worksteal'}"
  }
  if (opts.numShards) {
    parts << "--num-shards ${opts.numShards} --shard-id ${opts.shardId}"
  }
  parts << "--junitxml=${opts.stash}.xml --html=${opts.stash}.html --self-contained-html"
  if (opts.extraArgs) { parts << opts.extraArgs }
  def cmd = parts.join(' ')
  echo "runPytest[${opts.stash}]: FINN_CI_MARKER='${opts.marker}'; ${cmd}"
  writeFile file: 'run-tests.sh', text:
      "#!/bin/bash\nset -o pipefail\nexport FINN_CI_MARKER='${opts.marker}'\n${cmd}\nec=\$?\n[ \$ec -eq 5 ] && exit 0 || exit \$ec\n"
  sh 'chmod 777 run-tests.sh'
  sh './run-docker.sh ./run-tests.sh'
}

// Silent no-op when the board's hw_deployment_* dir is absent because under
// hash sharding only one shard runs cnv-w2a2. assertZipBoardsEmitted is the
// safety net for the case where no shard produced it at all.
void findCopyZip(String board, String findDir, String copyDir) {
  if (!fileExists("${findDir}")) { return }
  def found = sh(returnStdout: true, script:
      "find ${findDir} -maxdepth 2 -type d -name '${board}' -path '*/hw_deployment_*/*' | head -1"
  ).trim()
  if (!found) { return }
  // Reused workspaces can leave a stale ${copyDir}/${board} from an earlier
  // build whose read-only .git/objects/pack/ blocks both rm and cp -r.
  sh """
    mkdir -p '${copyDir}'
    if [ -e '${copyDir}/${board}' ]; then
      chmod -R u+w '${copyDir}/${board}'
      rm -rf '${copyDir}/${board}'
    fi
    cp -r '${found}' '${copyDir}/'
  """
  dir(copyDir) {
    sh "zip -r ${board}.zip ${board}/"
    sh "mkdir -p ${env.ARTIFACT_DIR}/${copyDir}/"
    sh "cp ${board}.zip ${env.ARTIFACT_DIR}/${copyDir}/"
  }
}
