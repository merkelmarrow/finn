import groovy.transform.Field

// =============================================================================
// Tables — edit these to add/remove/re-bucket what runs in the parallel block.
// =============================================================================

// BNN end2end pytest markers; keys mirror test_board_map in
// tests/end2end/test_end2end_bnn_pynq.py and the markers in setup.cfg.
@Field
Map<String, String> BNN_BOARD_MARKERS = [
    'U250'     : 'bnn_u250',
    'Pynq-Z1'  : 'bnn_pynq',
    'ZCU104'   : 'bnn_zcu104',
    'KV260_SOM': 'bnn_kv260',
]

// BNN end2end sub-stages — one Jenkins executor per row.
//
// cnv-w2a2 dominates each board's wall-clock (~35-50 %) because impl runtime
// scales super-linearly with bitwidth, so it is isolated on every board.
// Other scenarios are bucketed to keep the executor count down.
//
// Schema per row: board (key in BNN_BOARD_MARKERS), label (sub-stage suffix),
// keyword (pytest -k expression), workers (xdist -n value).
//
// Note: cnv configurations with wbits > abits (e.g. w2a1) are skipped by
// test_end2end_bnn_pynq.py::test_export, so do not list them here.
@Field
List<Map> BNN_SUB_STAGES = [
    [board: 'U250',      label: 'cnv-w2a2',      keyword: 'cnv and w2 and a2',                workers: 2],
    [board: 'U250',      label: 'cnv-w1a2',      keyword: 'cnv and w1 and a2',                workers: 2],
    [board: 'U250',      label: 'cnv-w1a1-tfc',  keyword: '(cnv and w1 and a1) or tfc',       workers: 4],
    [board: 'U250',      label: 'lfc',           keyword: 'lfc',                              workers: 2],
    [board: 'ZCU104',    label: 'cnv-heavy',     keyword: 'cnv and w2',                       workers: 4],
    [board: 'ZCU104',    label: 'cnv-light-tfc', keyword: '(cnv and w1) or tfc',              workers: 4],
    [board: 'ZCU104',    label: 'lfc',           keyword: 'lfc',                              workers: 2],
    [board: 'Pynq-Z1',   label: 'cnv-w2a2',      keyword: 'cnv and w2 and a2',                workers: 2],
    [board: 'Pynq-Z1',   label: 'cnv-rest-tfc',  keyword: '(cnv and not (w2 and a2)) or tfc', workers: 4],
    [board: 'Pynq-Z1',   label: 'lfc',           keyword: 'lfc',                              workers: 2],
    [board: 'KV260_SOM', label: 'cnv-w2a2',      keyword: 'cnv and w2 and a2',                workers: 2],
    [board: 'KV260_SOM', label: 'rest',          keyword: 'not (cnv and w2 and a2)',          workers: 4],
]

// End2end shards. Mobilenet carries ~32 xdist_group marks and dominates the
// stage wall; everything else fits comfortably into a lighter shard.
@Field
List<String> END2END_MOBILENET = [
    'tests/end2end/test_end2end_mobilenet_v1.py',
]

