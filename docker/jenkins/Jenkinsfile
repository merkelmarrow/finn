import groovy.transform.Field

// Edit these tables to add/remove/re-bucket what runs in the parallel block.

@Field
Map<String, String> BNN_BOARD_MARKERS = [
    'U250'     : 'bnn_u250',
    'Pynq-Z1'  : 'bnn_pynq',
    'ZCU104'   : 'bnn_zcu104',
    'KV260_SOM': 'bnn_kv260',
]

// One parallel sub-stage per row. cnv-w2a2 dominates each board's wall because
// impl runtime scales super-linearly with bitwidth, so it is isolated on every
// board. wbits > abits configs (e.g. w2a1) are skipped by test_export upstream
// and must not be listed here.
@Field
List<Map> BNN_SUB_STAGES = [
    [board: 'U250',      label: 'cnv-w2a2',      keyword: 'cnv and w2 and a2',                workers: 2],
    [board: 'U250',      label: 'cnv-w1a2',      keyword: 'cnv and w1 and a2',                workers: 2],
    [board: 'U250',      label: 'cnv-w1a1-tfc',  keyword: '(cnv and w1 and a1) or tfc',       workers: 4],
    [board: 'U250',      label: 'lfc',           keyword: 'lfc',                              workers: 2],
    [board: 'ZCU104',    label: 'cnv-heavy',     keyword: 'cnv and w2',                       workers: 4],
    [board: 'ZCU104',    label: 'cnv-light-tfc', keyword: '(cnv and w1) or tfc',              workers: 4],
    [board: 'ZCU104',    label: 'lfc',           keyword: 'lfc',                              workers: 2],
    [board: 'Pynq-Z1',   label: 'cnv-w2a2',      keyword: 'cnv and w2 and a2',                workers: 2],
    [board: 'Pynq-Z1',   label: 'cnv-rest-tfc',  keyword: '(cnv and not (w2 and a2)) or tfc', workers: 4],
    [board: 'Pynq-Z1',   label: 'lfc',           keyword: 'lfc',                              workers: 2],
    [board: 'KV260_SOM', label: 'cnv-w2a2',      keyword: 'cnv and w2 and a2',                workers: 2],
    [board: 'KV260_SOM', label: 'rest',          keyword: 'not (cnv and w2 and a2)',          workers: 4],
]

// Mobilenet carries ~32 xdist_group marks and dominates the stage wall.
@Field
List<Map> END2END_SHARDS = [
    [label: 'mobilenet', workers: 8, files: [
        'tests/end2end/test_end2end_mobilenet_v1.py',
    ]],
    [label: 'rest', workers: 4, files: [
        'tests/end2end/test_end2end_bnn_pynq.py',
        'tests/end2end/test_end2end_cybsec_mlp.py',
        'tests/end2end/test_ext_weights.py',
        'tests/end2end/test_ooc_synthesis.py',
    ]],
]

// fpgadataflow shard A: explicit heavy-file allowlist. Shard B is the
// catch-all (tests/fpgadataflow/ minus this list), so a new test file lands
// on shard B with no Jenkinsfile edit. Regenerate with
// scripts/balance_fpgadataflow_shards.py if shards drift > 15 %.
@Field
List<String> FPGADATAFLOW_SHARD_A = [
    'tests/fpgadataflow/test_code_gen_trafo.py',
    'tests/fpgadataflow/test_convert_to_hw_1d_conv_layer.py',
    'tests/fpgadataflow/test_convert_to_hw_conv_layer.py',
    'tests/fpgadataflow/test_convert_to_hw_layers_fc.py',
    'tests/fpgadataflow/test_convert_to_hw_pool_batch.py',
    'tests/fpgadataflow/test_fifosizing.py',
    'tests/fpgadataflow/test_fpgadataflow_checksum.py',
    'tests/fpgadataflow/test_fpgadataflow_convinputgenerator.py',
    'tests/fpgadataflow/test_fpgadataflow_crop.py',
    'tests/fpgadataflow/test_fpgadataflow_downsampler.py',
    'tests/fpgadataflow/test_fpgadataflow_dwc.py',
    'tests/fpgadataflow/test_fpgadataflow_elementwise_binary.py',
    'tests/fpgadataflow/test_fpgadataflow_fifo.py',
    'tests/fpgadataflow/test_fpgadataflow_fmpadding.py',
