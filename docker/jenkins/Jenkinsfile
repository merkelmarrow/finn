// Jenkins-only sharding config and timing helpers live in docker/jenkins/ci_sharding.py.
// Shared Groovy utilities (paramBool, paramString, shellQuote, ...) live in
// docker/jenkins/_common.groovy and are loaded once during Validate.

import groovy.transform.Field

@Field
def _common = null

// load() needs an active node and a checked-out workspace. The first stage
// (Validate) covers both, so this runs there and the loaded module is shared
// with every subsequent stage on every agent.
//
// load() needs an active workspace, but several wrappers are called later
// from no-agent orchestration code. Cache the stateless helper script after
// Validate so those calls do not depend on a node allocation.
private def loadCommonOnce() {
  if (_common == null) { _common = load 'docker/jenkins/_common.groovy' }
  return _common
}

@Field
List<Map> PARALLEL_SHARDS = []

// Set of CI param names the current STAGES choice enables. Populated by
// loadStageConfig() in Validate; rowIsActive() reads it as a set lookup.
@Field
List<String> ENABLED_PARAMS = []

@Field
String FINN_CI_TIMINGS_MASTER = ''

@Field
String FINN_CI_TIMINGS_SNAPSHOT = ''

// Cached job_key, populated once during Validate by loadStageConfig() so
// helpers that need it (per-build paths, prune subcommands) don't reshell
// out per stage. ci_sharding.py is the single source of truth for the
// sanitisation rule, including the leading/trailing dot strip that
// prevents JOB_NAME=".." escaping out of the prune parent.
@Field
String FINN_CI_JOB_KEY = ''

// Sized for ~2 concurrent build trees per agent (~60-80 GB each) plus headroom.
@Field
int FINN_CI_MIN_FREE_GB = 120

// Per-tree rotation policy. Loaded once during Validate from
// ci_sharding.RETENTION so SW pipeline and CLI prune subcommands cannot
// drift. See the Python side for the rationale on each tree's depth.
@Field
Map RETENTION = [:]

// One env var configures the whole FINN CI NFS layout. Set FINN_CI_NFS_ROOT
// in the job DSL and the SW pipeline derives every shared subtree from it.
// When FINN_CI_NFS_ROOT is unset the pipeline runs in local fallback mode:
// shards execute per-agent, each agent builds its own Docker image, no
// SW->HW handoff is staged, no timing master persists across builds. HW
// jobs require FINN_CI_NFS_ROOT and error fast if it is unset.
//
// Layout under ${FINN_CI_NFS_ROOT} (full mode):
//   agent_caches/<NODE>/{xrt,finn_cache,vivado_ip_cache}   per-agent caches
//   docker_images/<jobKey>/<BUILD>/                        shared docker image
//   artifacts/ci_runs/<jobKey>/<BUILD>/                    SW->HW handoff + BUILD_INFO
//   _ci_state/<jobKey>/                                    timing master + snapshots
//
// Per-shard scratch lives at ${WORKSPACE}/tmp/ci_runs/<BUILD>/<stash>
// regardless of FINN_CI_NFS_ROOT: the workspace is per-agent (NFS-mounted
// on lab build hosts, local SSD elsewhere) and `git clean -ffdx` between
// runs handles rotation.
//
// Resolvers live in _common.groovy and are thin-wrapped here so call sites
// keep their original short names. All return '' in local fallback mode;
// callers MUST handle that.
String finnCiNfsRoot()                    { return loadCommonOnce().finnCiNfsRoot() }
String finnAgentCachesDir(String node)    { return loadCommonOnce().finnAgentCachesDir(node) }
String finnDockerImagesRoot()             { return loadCommonOnce().finnDockerImagesRoot() }
String finnDockerImagesDir(String jobKey) { return loadCommonOnce().finnDockerImagesDir(jobKey) }
String finnArtifactsRoot()                { return loadCommonOnce().finnArtifactsRoot() }
String finnCiStateDir(String jobKey)      { return loadCommonOnce().finnCiStateDir(jobKey) }

// Loud banner so a glance at the console log answers "is NFS visible
// and what features does this build have?". Printed unconditionally
// from Validate; the local-fallback branch lists each disabled feature
// explicitly so the next operator does not have to guess.
void announceCiMode() {
  String root = finnCiNfsRoot()
  if (root) {
    echo "[finn-ci] FINN_CI_NFS_ROOT=${root} (full operation)"
  } else {
    echo "[finn-ci] FINN_CI_NFS_ROOT is unset; running in local fallback mode."
    echo "[finn-ci]   - no shared Docker images (each agent builds locally)"
    echo "[finn-ci]   - no SW->HW artifact handoff (HW pipeline will fail against this build)"
    echo "[finn-ci]   - no persistent timing master (cold-start round-robin each build)"
    echo "[finn-ci]   - no per-agent NFS caches (network downloads run fresh)"
  }
}

// One subprocess for the entire Validate-time config bundle. ci_sharding.py
// validate_boards() runs first inside the subcommand so any orphan
// zipArtifact board fails Validate loudly instead of slipping into the
// per-shard runs. FINN_CI_JOB_KEY is populated eagerly here so later
// helpers (rotateBuildTree, prepareTimingState, ...) never need to lazy
// shell out for it.
void loadStageConfig() {
  String choice = paramString('STAGES') ?: 'sanity'
  String raw = sh(returnStdout: true, script:
    "python3 docker/jenkins/ci_sharding.py validate-config " +
    "--choice ${shellQuote(choice)} " +
    "--job-name ${shellQuote(env.JOB_NAME ?: 'job')}"
  ).trim()
  Map payload = readJSON(text: raw) as Map
  PARALLEL_SHARDS = (payload.stages as List).collect { it as Map }
  ENABLED_PARAMS  = (payload.enabled_params as List).collect { it as String }
  RETENTION       = payload.retention as Map
  FINN_CI_JOB_KEY = payload.job_key as String
}

// Marker is interpolated into a shell command, so reject anything that could escape it.
@Field
java.util.regex.Pattern MARKER_SAFE_PATTERN = ~/^[A-Za-z0-9_ ]+$/

pipeline {
  agent none
  options {
    timeout(time: 72, unit: 'HOURS')
  }
  parameters {
    // STAGES is the only knob most operators ever touch. Choices mirror
    // ci_sharding.jenkins_stage_choices(): ``sanity`` is the per-PR
    // default, ``full`` runs every CI param, and the bare param names
    // let a contributor debug just one slice. Drift between the two
    // sides is caught by test_jenkinsfile_stage_choices_match_python_source.
    choice(name: 'STAGES',
           choices: ['sanity', 'full', 'fpgadataflow', 'end2end'],
           description: 'Which CI rows to run. ' +
                        'sanity (default) = sanity rows only, ~per-PR quick check. ' +
                        'full = every CI row, ~nightly. ' +
                        'fpgadataflow / end2end = just that one family, ' +
                        'useful for debugging a single slice without STAGE_FILTER.')
    booleanParam(name: 'local_setup',  defaultValue: false,
                 description: 'Run the non-Docker Vivado setup test on the finn-local-build host. ' +
                              'Slow and orthogonal to STAGES. Leave off unless you are working ' +
                              'on setup-local.sh itself.')
    string(name: 'STAGE_FILTER', defaultValue: '',
           description: 'Substring filter for debugging a single shard. ' +
                        'Leave empty for a normal build.')
  }
  stages {
    // Funnel per-agent config through withAgentNfsEnv so adding a finn-build
    // host is a jenkins_slaves.yml edit only, never a Jenkinsfile edit.
    stage('Validate') {
      agent { label 'finn-build' }
      steps {
        script {
          wipeStaleWorkspace()
          announceCiMode()
          withAgentNfsEnv {
            loadStageConfig()
            prepareTimingState()
            validateShards()
            rotateBuildTrees()
            writeBuildInfo()
          }
        }
      }
    }
    stage('Build Docker Image') {
      agent { label 'finn-build' }
      environment { FINN_DOCKER_PREBUILT = '0' }
      steps { script { wipeStaleWorkspace(); withAgentNfsEnv { buildAndPublishDockerImage() } } }
    }
    stage('Run Tests') {
      steps { script { runParallelOrFail(buildParallelStageMap()) } }
    }
    stage('Check Stage Results') {
      agent { label 'finn-build' }
      steps { script { withAgentNfsEnv { aggregateReports() } } }
    }
  }
}

// Thin wrappers around docker/jenkins/_common.groovy.
boolean paramBool(String name)   { return loadCommonOnce().paramBool(name) }
String  paramString(String name) { return loadCommonOnce().paramString(name) }
String  shellQuote(String s)     { return loadCommonOnce().shellQuote(s) }

// Marker errors are fatal. Executor over-subscription only warns (queueing recovers).
void validateShards() {
  if (!PARALLEL_SHARDS) {
    error "PARALLEL_SHARDS is empty. loadStageConfig() must run before validateShards()"
  }
  // CPS: see eachActiveShard for the IntRange/closure-serialisation caveat.
  for (int rowIdx = 0; rowIdx < PARALLEL_SHARDS.size(); rowIdx++) {
    Map row = PARALLEL_SHARDS[rowIdx]
    if (!MARKER_SAFE_PATTERN.matcher(row.marker as String).matches()) {
      error "PARALLEL_SHARDS row '${row.stage}' has unsafe marker '${row.marker}' (only [A-Za-z0-9_ ] allowed)"
    }
    if (!(row.shards instanceof Integer) || (row.shards as int) < 1) {
      error "PARALLEL_SHARDS row '${row.stage}' has invalid shards=${row.shards}"
    }
  }
  def activeCount = 0
  eachActiveShard { row, id -> activeCount++ }
  // STAGE_FILTER mismatch is fatal so a silent zero-shard "green" build
  // cannot mask a typo. The error lists active stage names so the operator
  // does not have to guess what the filter should look like.
  String filter = resolveStageFilter()
  if (filter && activeCount == 0) {
    def candidates = []
    for (int rowIdx = 0; rowIdx < PARALLEL_SHARDS.size(); rowIdx++) {
      Map row = PARALLEL_SHARDS[rowIdx]
      if (rowIsActive(row)) { candidates << (row.stage as String) }
    }
    if (candidates) {
      error "STAGE_FILTER='${filter}' matched no shards. Active stages under " +
            "STAGES=${paramString('STAGES')} are: " +
            candidates.join(', ')
    }
    error "STAGE_FILTER='${filter}' matched 0 rows because no rows are active under STAGES=${paramString('STAGES')}"
  }
  int available = 0
  try {
    def lbl = Jenkins.instance.getLabelAtom('finn-build')
    if (lbl) { available = lbl.getTotalExecutors() }
  } catch (Exception e) {
    echo "validateShards: executor query failed (${e.class.name}: ${e.message}), skipping budget check"
  }
  if (available > 0) {
    echo "validateShards: ${activeCount} shard(s) active, finn-build executors available: ${available}"
    if (activeCount > available) {
      unstable "PARALLEL_SHARDS requests ${activeCount} parallel shards but only ${available} finn-build executors are available, stages will queue and wall-clock will extend"
    }
  } else {
    echo "validateShards: ${activeCount} shard(s) active, finn-build label has 0 online executors, skipping budget check"
  }
}

void buildAndPublishDockerImage() {
  sh 'docker system prune -a -f'
  sh "./run-docker.sh echo 'Docker image build complete'"
  String imageDir = buildDockerImageDir()
  if (imageDir) {
    publishSharedDockerImage(imageDir)
  } else {
    echo "buildAndPublishDockerImage: local fallback mode, skipping image publish"
  }
}

// Build-scoped image directory under FINN_CI_NFS_ROOT, or '' in local
// fallback mode.
String buildDockerImageDir() {
  String parent = finnDockerImagesDir(finnCiJobKey())
  if (!parent) { return '' }
  return "${parent}/${env.BUILD_NUMBER}"
}

// Other agents docker load this image instead of rebuilding. Tag derives
// from `./run-docker.sh print-tag` so the tag string has one source of
// truth. The build-scoped imageDir isolates cross-build readers from
// in-progress writes, so rename ordering is defence-in-depth only. The
// flock guards a same-build retry of the Build Docker Image stage racing
// against itself; the tag file is renamed last so an out-of-band peek
// that observes the new tag is still guaranteed to find the matching image.
void publishSharedDockerImage(String imageDir) {
  def tag = sh(returnStdout: true, script: './run-docker.sh print-tag').trim()
  if (!tag || tag.contains('\n')) {
    error "run-docker.sh print-tag must emit exactly one Docker tag line; got: ${tag}"
  }
  sh "mkdir -p ${shellQuote(imageDir)}"
  // bash for set -o pipefail because Jenkins defaults sh to dash. flock via
  // a numeric fd avoids nested-quote gymnastics. The lock is released when
  // the shell exits (no explicit unlock needed).
  sh """#!/bin/bash
set -eo pipefail
image_dir=${shellQuote(imageDir)}
tag=${shellQuote(tag)}
build=${shellQuote(env.BUILD_NUMBER ?: '')}
tmp_img="\${image_dir}/finn-docker-image.tar.gz.tmp-\${build}"
tmp_tag="\${image_dir}/finn-docker-tag.txt.tmp-\${build}"
final_img="\${image_dir}/finn-docker-image.tar.gz"
final_tag="\${image_dir}/finn-docker-tag.txt"
exec 9>"\${image_dir}/.publish.lock"
flock -x 9
rm -f "\$tmp_img" "\$tmp_tag"
if command -v pigz >/dev/null 2>&1; then
  docker save "\$tag" | pigz -p \$(nproc) > "\$tmp_img"
else
  docker save "\$tag" | gzip > "\$tmp_img"
fi
printf '%s\\n' "\$tag" > "\$tmp_tag"
sync "\$tmp_img" "\$tmp_tag"
mv "\$tmp_img" "\$final_img"
mv "\$tmp_tag" "\$final_tag"
"""
}

Map<String, Closure> buildParallelStageMap() {
  def branches = [:]
  eachActiveShard { row, id ->
    String stage = shardStageName(row, id)
    String stash = shardStashName(row, id)
    branches[stage] = { runShard(row, id, stage, stash) }
  }
  if (paramBool('local_setup')) {
    branches['Local Setup (non-Docker) with Vivado'] = { runLocalSetupTest() }
  }
  return branches
}

void runParallelOrFail(Map<String, Closure> branches) {
  if (!branches) {
    error "No CI stages selected. STAGES=${paramString('STAGES')}, " +
          "ENABLED_PARAMS=${ENABLED_PARAMS}, STAGE_FILTER='${resolveStageFilter()}'"
  }
  parallel(branches)
}

// A row runs iff its CI-progression param is enabled by the current STAGES
// choice (membership in ENABLED_PARAMS). Single source of truth for the gate
// used by eachActiveShard, hasActiveArtifactRows, assertZipArtifactsEmitted,
// and aggregatePublishedBoardZips.
boolean rowIsActive(Map row) {
  return ENABLED_PARAMS.contains(row.param as String)
}

String resolveStageFilter() { return paramString('STAGE_FILTER') }

void eachActiveShard(Closure body) {
  String filter = resolveStageFilter()
  for (int rowIdx = 0; rowIdx < PARALLEL_SHARDS.size(); rowIdx++) {
    Map row = PARALLEL_SHARDS[rowIdx]
    if (!rowIsActive(row)) { continue }
    int numShards = row.shards as int
    // C-style for-loop because groovy.lang.IntRange is not Serializable and
    // breaks CPS persistence when it survives into parallel(...).
    for (int id = 0; id < numShards; id++) {
      String stage = shardStageName(row, id)
      if (filter && !stage.contains(filter)) { continue }
      body.call(row, id)
    }
  }
}

String shardStageName(Map row, int id) {
  return row.shards == 1 ? row.stage : "${row.stage} (${id + 1}/${row.shards})"
}

String shardStashName(Map row, int id) {
  String base = row.stage.toLowerCase().replaceAll(/[^a-z0-9]+/, '_').replaceAll(/^_|_$/, '')
  return row.shards == 1 ? base : "${base}_${id + 1}"
}

// jobKey under ci_runs/ keeps two jobs that happen to share a build number
// on the same host from colliding. The sanitisation rule lives in
// ci_sharding.py so SW and HW pipelines cannot diverge. Populated eagerly
// by loadStageConfig() during Validate; callers downstream of that are
// pure accessors with no subprocess cost.
String finnCiJobKey() {
  if (!FINN_CI_JOB_KEY) {
    error "finnCiJobKey: FINN_CI_JOB_KEY is unset. loadStageConfig() must run before any helper that reads it."
  }
  return FINN_CI_JOB_KEY
}

// Per-build artifact root under ${FINN_CI_NFS_ROOT}/artifacts, or '' in
// local fallback mode. Callers that require the path must check the
// return value.
String artifactBuildRoot() {
  String base = finnArtifactsRoot()
  if (!base) { return '' }
  return "${base}/ci_runs/${finnCiJobKey()}/${env.BUILD_NUMBER}"
}

// boardZipPath is the canonical SW->HW handoff path. SW writes the zip
// plus a sibling READY marker here, HW resolves per (testType, board) to
// the newest build whose READY exists. HW reads via the
// resolveSwBoardZipPath helper in Jenkinsfile_HW, not via this function.
//
// Errors in local fallback mode rather than returning '' so a future caller
// cannot accidentally fileExists('.READY') in the agent workspace. Callers
// MUST gate on finnArtifactsRoot() (or equivalent) before invoking.
String boardZipPath(String testType, String board) {
  String root = artifactBuildRoot()
  if (!root) {
    error "boardZipPath(${testType}/${board}): artifact tree unavailable. " +
          "Callers must gate on finnArtifactsRoot() before invoking."
  }
  return "${root}/zips/${testType}/${board}.zip"
}

boolean hasActiveArtifactRows() {
  for (int rowIdx = 0; rowIdx < PARALLEL_SHARDS.size(); rowIdx++) {
    Map row = PARALLEL_SHARDS[rowIdx]
    if (!rowIsActive(row)) { continue }
    if (row.zipArtifacts) { return true }
  }
  return false
}

// Human-readable "row -> board(s)" list for the local-fallback warning so the
// operator sees which handoff slots they lost without diffing STAGES.
String activeArtifactRowSummary() {
  def parts = []
  for (int rowIdx = 0; rowIdx < PARALLEL_SHARDS.size(); rowIdx++) {
    Map row = PARALLEL_SHARDS[rowIdx]
    if (!rowIsActive(row)) { continue }
    Map zipArt = row.zipArtifacts as Map
    if (!zipArt) { continue }
    parts << "${row.stage} -> ${(zipArt.boards ?: []).join(',')}"
  }
  return parts.join('; ')
}

void prepareTimingState() {
  FINN_CI_TIMINGS_MASTER = ''
  FINN_CI_TIMINGS_SNAPSHOT = ''
  String stateDir = finnCiStateDir(finnCiJobKey())
  if (!stateDir) {
    echo "prepareTimingState: local fallback mode, sharding will cold-start to round-robin"
    return
  }
  String master = "${stateDir}/ci_timings_master.json"
  String snapshot = "${stateDir}/build_${env.BUILD_NUMBER}_timings_input.json"
  catchError(buildResult: null, stageResult: null,
             message: 'prepareTimingState failed, sharding will cold-start to round-robin') {
    sh "mkdir -p ${shellQuote(stateDir)}"
    sh "python3 docker/jenkins/ci_sharding.py prepare " +
       "--master ${shellQuote(master)} --snapshot ${shellQuote(snapshot)}"
    FINN_CI_TIMINGS_MASTER = master
    FINN_CI_TIMINGS_SNAPSHOT = snapshot
    echo "prepareTimingState: using ${snapshot}"
  }
}

// Human-readable per-build traceability file. Never parsed by code, only
// `cat`ed by operators. Lives alongside the zips so the HW pipeline can
// archive it for cross-reference in the HW build description.
// GIT_COMMIT/BRANCH_NAME/GIT_BRANCH are set by checkout scm. A direct
// `git rev-parse HEAD` on a detached checkout would record "HEAD" as the
// branch. writeFile takes the body verbatim, so operator-controlled values
// (STAGE_FILTER, git_branch) cannot trigger shell expansion.
void writeBuildInfo() {
  String enabled = ENABLED_PARAMS.join(',')
  String commit = env.GIT_COMMIT ?: ''
  String branch = env.BRANCH_NAME ?: (env.GIT_BRANCH ?: '')
  String imageDir = buildDockerImageDir()
  String buildRoot = artifactBuildRoot()
  String timestamp = sh(returnStdout: true, script: 'date -u +%FT%TZ').trim()
  String body = [
    "job_name=${env.JOB_NAME ?: ''}",
    "job_key=${finnCiJobKey()}",
    "build_number=${env.BUILD_NUMBER ?: ''}",
    "git_commit=${commit}",
    "git_branch=${branch}",
    "enabled_params=${enabled}",
    "stage_filter=${resolveStageFilter()}",
    "timings_snapshot=${FINN_CI_TIMINGS_SNAPSHOT ?: ''}",
    "docker_image_dir=${imageDir}",
    "validate_node=${env.NODE_NAME ?: ''}",
    "generated_at=${timestamp}",
    '',
  ].join('\n')
  if (buildRoot) {
    sh "mkdir -p ${shellQuote(buildRoot)}"
    writeFile file: "${buildRoot}/BUILD_INFO.txt", text: body
  } else {
    writeFile file: 'BUILD_INFO.txt', text: body
  }
}

// Per-shard scratch under ${WORKSPACE}/tmp. The workspace is per-agent
// (NFS-shared on lab build hosts via remote_fs, local SSD on non-NFS
// agents) and ``git clean -ffdx`` between runs handles rotation, so no
// cross-build prune is needed for tmp anymore.
String finnCiPerBuildRoot() {
  if (!env.BUILD_NUMBER) { error "BUILD_NUMBER is unset" }
  String ws = env.WORKSPACE
  if (!ws) { error "WORKSPACE is unset" }
  return "${ws}/tmp/ci_runs/${env.BUILD_NUMBER}"
}

// Generic per-build-tree rotation. Image and artifact trees live under
// FINN_CI_NFS_ROOT and are shared across agents. Skips silently when
// the root is empty (local fallback mode) or the parent directory does
// not exist (cold-start). Per-shard scratch is workspace-local and
// rotated by git clean, no explicit prune subcommand for it.
void rotateBuildTree(String subcommand, String root, Map policy) {
  catchError(buildResult: null, stageResult: null,
             message: "${subcommand} failed, non-fatal") {
    if (!root) { return }
    sh "python3 docker/jenkins/ci_sharding.py ${subcommand} " +
       "${shellQuote(root)} ${shellQuote(finnCiJobKey())} ${shellQuote(env.BUILD_NUMBER ?: '')} " +
       "${policy.retain} ${policy.ageDays}"
  }
}

void rotateBuildTrees() {
  rotateBuildTree('prune-images', finnDockerImagesRoot(), RETENTION.image)
  rotateBuildTree('prune-artifacts', finnArtifactsRoot(), RETENTION.artifact)
}

// Must run after node binding so ${NODE_NAME} resolves before
// FINN_DOCKER_EXTRA is interpolated. Hostname pin is unconditional:
// bsub's gethostbyname() on the default finn_dev_<user> fails with
// "Error 0". Cache mounts and the build-scoped shared-image hint are
// added only when FINN_CI_NFS_ROOT is set; in local fallback mode each
// agent operates self-contained.
void withAgentNfsEnv(Closure body) {
  String node = env.NODE_NAME ?: 'localhost'
  String dockerExtra = "${env.FINN_DOCKER_EXTRA ?: ''} --hostname ${node}"
  List<String> envList = []
  String cachesDir = finnAgentCachesDir(node)
  if (cachesDir) {
    sh "mkdir -p ${shellQuote(cachesDir + '/xrt')} " +
       "${shellQuote(cachesDir + '/finn_cache')} " +
       "${shellQuote(cachesDir + '/vivado_ip_cache')}"
    dockerExtra += " -v ${cachesDir}/vivado_ip_cache:/tmp/vivado_ip_cache"
    envList << "FINN_XRT_PATH=${cachesDir}/xrt"
    envList << "FINN_DOCKER_CACHE_DIR=${cachesDir}/finn_cache"
  }
  envList << "FINN_DOCKER_EXTRA=${dockerExtra}"
  String imageDir = buildDockerImageDir()
  if (imageDir) {
    envList << "FINN_DOCKER_SHARED_IMAGE_DIR=${imageDir}"
  } else {
    envList << "FINN_DOCKER_PREBUILT=0"
  }
  withEnv(envList) { body() }
}

// Cold start so stale outputs don't mask ordering bugs in a reused
// workspace. The post-clean ``git status --porcelain`` check fails
// loudly if the workspace still has changes afterwards (root-owned
// residue, NFS permission glitches), since the rest of the pipeline
// assumes the working tree matches the checkout.
void wipeStaleWorkspace() {
  sh '''
    git clean -ffdx
    dirty=$(git status --porcelain)
    if [ -n "$dirty" ]; then
      n=$(echo "$dirty" | wc -l)
      echo "wipeStaleWorkspace: ${n} dirty path(s) after git clean -ffdx (showing first 20):"
      echo "$dirty" | head -20
      exit 1
    fi
  '''
}

// finally is load-bearing so failed stages still publish their JUnit XML.
void runShard(Map row, int shardIdx, String stageName, String stashName) {
  node('finn-build') {
    withAgentNfsEnv {
      stage(stageName) {
        checkout scm
        wipeStaleWorkspace()
        String perBuildRoot = finnCiPerBuildRoot()
        String buildDir = "${perBuildRoot}/${stashName}"
        String startMarker = "${perBuildRoot}/${stashName}.start"
        String stageMap = "[stage-map] build=${env.BUILD_NUMBER} stage='${stageName}' stash=${stashName} shard=${shardIdx + 1}/${row.shards} node=${env.NODE_NAME} workspace=${env.WORKSPACE} build_dir=${buildDir}"
        echo stageMap
        writeFile file: "${stashName}.stagemap", text: "${stageMap}\n"
        withEnv(["FINN_HOST_BUILD_DIR=${buildDir}"]) {
          sh "mkdir -p ${shellQuote(perBuildRoot)}"
          sh "touch ${shellQuote(startMarker)}"
          checkAgentFreeSpace(FINN_CI_MIN_FREE_GB)
          sh "mkdir -p ${shellQuote(stashName)}"
          cleanPreviousBuildFiles(buildDir)
          try {
            catchError(stageResult: 'FAILURE') {
              runShardBody(row, shardIdx, stageName, stashName, buildDir, startMarker)
            }
          } finally {
            safeStashReport(stashName)
          }
        }
      }
    }
  }
}

// Inner try/catch surfaces tool logs + tarballs them for Blue Ocean triage
// before the outer catchError marks the stage red.
void runShardBody(Map row, int shardIdx, String stageName, String stashName, String buildDir, String startMarker) {
  try {
    Map opts = [
        marker: row.marker,
        stage: stageName,
        stash: stashName,
        workers: row.workers as int,
        distMode: row.distMode,
        numShards: row.shards as int,
        shardId: shardIdx,
    ]
    if (row.coverage) {
      opts.extraArgs = "--cov --cov-report=html:coverage_${stashName}"
    }
    runPytest(opts)
    if (row.coverage) { archiveStageFolder("coverage_${stashName}") }
    Map zipArt = row.zipArtifacts as Map
    if (zipArt) {
      String testType = zipArt.hwTestType as String
      (zipArt.boards ?: []).each { board ->
        findCopyZip(testType, board, buildDir, stashName)
      }
    }
    printLsfSummary(buildDir, stashName)
  } catch (Exception e) {
    printLsfSummary(buildDir, stashName)
    printPytestFailures(stashName, 50, 20)
    printFailureTails(buildDir, stashName, 150)
    archiveFailureLogs(buildDir, stashName, startMarker)
    throw e
  }
}

// Pinned to a local-build host because finn-build hosts are not
// guaranteed to have the apt/python3.10 prerequisites that setup-local.sh expects. Run
// scripts/install-system-deps.sh on the agent once before enabling.
// pip and XDG caches go to /scratch/jenkins because /home/cse-jenkins is
// small and a cold pip install overflows it.
void runLocalSetupTest() {
  node('finn-local-build') {
    withAgentNfsEnv {
      stage('Local Setup (non-Docker) with Vivado') {
        checkout scm
        wipeStaleWorkspace()
        String perBuildRoot = finnCiPerBuildRoot()
        String buildDir = "${perBuildRoot}/local_setup"
        echo "[stage-map] build=${env.BUILD_NUMBER} stage='Local Setup (non-Docker) with Vivado' stash=local_setup shard=1/1 node=${env.NODE_NAME} workspace=${env.WORKSPACE} build_dir=${buildDir}"
        // Cache key tracks the dep inputs so changes force a fresh download.
        String pipCacheKey = sh(
          returnStdout: true,
          script: 'sha256sum requirements.txt setup.py setup.cfg pyproject.toml 2>/dev/null | sha256sum | cut -c1-16'
        ).trim()
        if (!pipCacheKey) { pipCacheKey = "build-${env.BUILD_NUMBER}" }
        String pipCacheRoot = '/scratch/jenkins/.pip-cache'
        String pipCacheDir  = "${pipCacheRoot}/${pipCacheKey}"
        String xdgCacheDir  = '/scratch/jenkins/.xdg-cache'
        withEnv([
          "FINN_HOST_BUILD_DIR=${buildDir}",
          "PIP_CACHE_DIR=${pipCacheDir}",
          "XDG_CACHE_HOME=${xdgCacheDir}",
        ]) {
          sh """
mkdir -p '${perBuildRoot}' '${pipCacheDir}' '${xdgCacheDir}'
find '${pipCacheRoot}' -mindepth 1 -maxdepth 1 -type d -mtime +14 -not -path '${pipCacheDir}' \\
  -exec rm -rf {} + 2>/dev/null || true
"""
          cleanPreviousBuildFiles(buildDir)
          catchError(stageResult: 'FAILURE') {
            sh './setup-local.sh'
            sh '''#!/bin/bash
set -eo pipefail
source scripts/finn-env.sh
./scripts/quicktest-local.sh vivado
'''
          }
        }
      }
    }
  }
}

// catchError keeps a stash hiccup from masking pytest's own pass/fail. The
// SW form stashes the full per-shard sidecar set, see _common.groovy.
void safeStashReport(String stashName) { loadCommonOnce().safeStashShardReport(stashName) }

// Swallowing the missing-stash exception lets aggregation still see the rest.
void unstashIfPresent(String stashName) { loadCommonOnce().unstashIfPresent(stashName) }

void archiveStageFolder(String folder) {
  catchError(buildResult: null, stageResult: null,
             message: "archiveArtifacts(${folder}) failed, non-fatal") {
    archiveArtifacts artifacts: "${folder}/**/*", allowEmptyArchive: true
  }
}

// Per-tool run counts + hosts so Blue Ocean shows LSF fan-out. Body lives
// in docker/jenkins/scripts/lsf_summary.sh so it can be shellcheck'd.
void printLsfSummary(String buildDir, String stashName) {
  catchError(buildResult: null, stageResult: null,
             message: "printLsfSummary(${stashName}) failed, non-fatal") {
    sh "docker/jenkins/scripts/lsf_summary.sh " +
       "${shellQuote(buildDir)} ${shellQuote(env.NODE_NAME ?: '')} ${shellQuote(stashName)}"
  }
}

// Per-test failure summary from JUnit XML. Covers cases printFailureTails
// misses when no tool log exists (notebook timeouts, asserts, fixture errors).
// Body lives in docker/jenkins/scripts/print_pytest_failures.py so it is
// flake8-lintable.
void printPytestFailures(String stashName, int linesPerFailure, int maxFailures) {
  catchError(buildResult: null, stageResult: null,
             message: "printPytestFailures(${stashName}) failed, non-fatal") {
    String xml = "${stashName}.xml"
    if (!fileExists(xml)) {
      echo "[pytest-failures ${stashName}] no JUnit XML at ${xml}"
      return
    }
    sh "python3 docker/jenkins/scripts/print_pytest_failures.py " +
       "${shellQuote(xml)} ${shellQuote(stashName)} ${linesPerFailure} ${maxFailures}"
  }
}

// Tail every tool log with an ERROR: marker so the Jenkins console shows
// the actual error without downloading the artifact tarball. Body lives in
// docker/jenkins/scripts/failure_tails.sh so it can be shellcheck'd.
void printFailureTails(String buildDir, String stashName, int tailLines) {
  catchError(buildResult: null, stageResult: null,
             message: "printFailureTails(${stashName}) failed, non-fatal") {
    sh "docker/jenkins/scripts/failure_tails.sh " +
       "${shellQuote(buildDir)} ${shellQuote(stashName)} ${tailLines}"
  }
}

// One tarball per failed shard, keyed on stashName to avoid archive
// collisions. Body lives in docker/jenkins/scripts/archive_failure_logs.sh
// so it can be shellcheck'd. The script reads FINN_LSF_NFS_STAGING from
// the environment because LSF staging logs live outside the build dir.
void archiveFailureLogs(String buildDir, String stashName, String startMarker) {
  catchError(buildResult: null, stageResult: null,
             message: "archiveFailureLogs(${stashName}) failed, non-fatal") {
    String tarball = "failure_logs/${stashName}.tar.gz"
    String absTarball = "${env.WORKSPACE}/${tarball}"
    sh "docker/jenkins/scripts/archive_failure_logs.sh " +
       "${shellQuote(buildDir)} ${shellQuote(absTarball)} ${shellQuote(startMarker)}"
    archiveArtifacts artifacts: tarball, allowEmptyArchive: true
  }
}

// junit first (workspace-local, never flakes). html merge/archive after,
// because agent-to-controller tar transfer can flake on large globs.
void aggregateReports() {
  sh 'mkdir -p reports'
  cleanPreviousBuildFiles('reports')
  dir('reports') {
    expectedStashes().each { name -> unstashIfPresent(name) }
  }
  junit allowEmptyResults: true, testResults: 'reports/*.xml'
  mergeShardMaps()
  echoShardTimings()
  aggregatePublishedBoardZips()
  assertZipArtifactsEmitted()
  updateTimingState()
  publishStageMap()
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'pytest_html_merger failed, per-stage HTMLs still archived') {
    runDockerCommand('./run-docker.sh pytest_html_merger -i reports/ -o reports/test_report_final.html')
  }
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'archiveArtifacts (xml) failed') {
    archiveArtifacts artifacts: 'reports/*.xml', allowEmptyArchive: true
  }
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'archiveArtifacts (html) failed') {
    archiveArtifacts artifacts: 'reports/*.html', allowEmptyArchive: true
  }
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'archiveArtifacts (timings and shard maps) failed') {
    archiveArtifacts artifacts: 'reports/*.timings.json,reports/*shardmap.*,reports/shard_map.*,reports/ci_timings_master.json',
                     allowEmptyArchive: true
  }
}

// Sole writer of currentBuild.description on the SW pipeline. The HW pipeline
// owns its own currentBuild.description via archiveBuildInfo, the two never
// share a build.
void publishStageMap() {
  catchError(buildResult: null, stageResult: null,
             message: 'publishStageMap failed, non-fatal') {
    if (!fileExists('reports')) { return }
    sh "cat reports/*.stagemap 2>/dev/null | sort > reports/stage_map.txt || true"
    if (!fileExists('reports/stage_map.txt')) { return }
    archiveArtifacts artifacts: 'reports/stage_map.txt', allowEmptyArchive: true
    String body = readFile('reports/stage_map.txt').trim()
    if (body) {
      currentBuild.description = body
    }
  }
}

// Warns when a shard exceeds 1.5x its family median wall clock.
void echoShardTimings() {
  catchError(buildResult: null, stageResult: null,
             message: 'echoShardTimings failed, non-fatal') {
    if (!fileExists('reports')) { return }
    sh "python3 docker/jenkins/ci_sharding.py summarize reports/"
  }
}

void mergeShardMaps() {
  catchError(buildResult: null, stageResult: null,
             message: 'mergeShardMaps failed, non-fatal') {
    if (!fileExists('reports')) { return }
    sh "python3 docker/jenkins/ci_sharding.py merge-maps reports/"
  }
}

// Soft check that every active row declaring zipArtifacts produced its
// READY marker this build. Reads the canonical boardZipPath rather than
// workspace dirs, so it catches a row that silently failed to write the
// zip even though pytest itself passed. Marks the build UNSTABLE so HW
// pipeline operators see the regression without losing the per-board
// fallback to the previous READY. In local fallback mode (no shared
// artifact tree) this is a no-op: the Validate banner already explained
// that handoff is disabled.
void assertZipArtifactsEmitted() {
  catchError(buildResult: null, stageResult: null,
             message: 'assertZipArtifactsEmitted failed, non-fatal') {
    if (!finnArtifactsRoot()) {
      if (hasActiveArtifactRows()) {
        unstable "FINN_CI_NFS_ROOT unset: SW->HW handoff not staged this build (rows that would publish: " +
                 activeArtifactRowSummary() + "). Set FINN_CI_NFS_ROOT to enable handoff."
      } else {
        echo "assertZipArtifactsEmitted: local fallback mode (no shared artifact tree), skipping"
      }
      return
    }
    def missing = []
    // CPS: see eachActiveShard for the IntRange/closure-serialisation caveat.
    for (int rowIdx = 0; rowIdx < PARALLEL_SHARDS.size(); rowIdx++) {
      Map row = PARALLEL_SHARDS[rowIdx]
      if (!rowIsActive(row)) { continue }
      Map zipArt = row.zipArtifacts as Map
      if (!zipArt) { continue }
      String testType = zipArt.hwTestType as String
      List boards = (zipArt.boards ?: []) as List
      for (int b = 0; b < boards.size(); b++) {
        String board = boards[b] as String
        String ready = "${boardZipPath(testType, board)}.READY"
        if (!fileExists(ready)) {
          missing << "${row.stage} -> ${board} (no .READY at ${ready})"
        }
      }
    }
    if (!missing.isEmpty()) {
      echo "assertZipArtifactsEmitted: ${missing.size()} board zip(s) not produced this build:\n  - " + missing.join('\n  - ')
      unstable "assertZipArtifactsEmitted: ${missing.size()} board zip(s) not produced this build"
    }
  }
}

void updateTimingState() {
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'updateTimingState failed; persistent master may be stale') {
    if (!fileExists('reports')) { return }
    String masterArg = FINN_CI_TIMINGS_MASTER ? "--master ${shellQuote(FINN_CI_TIMINGS_MASTER)}" : ''
    String updateArg = shouldUpdatePersistentTimingState() ? '--update-master --allow-force-accept --gc' : ''
    sh "python3 docker/jenkins/ci_sharding.py update --reports reports ${masterArg} " +
       "--out reports/ci_timings_master.json " +
       "--job ${shellQuote(env.JOB_NAME ?: '')} --build ${shellQuote(env.BUILD_NUMBER ?: '')} " +
       "${updateArg}"
  }
}

boolean shouldUpdatePersistentTimingState() {
  String result = currentBuild.currentResult ?: 'SUCCESS'
  return result == 'SUCCESS' && paramString('STAGES') == 'full' && !resolveStageFilter()
}

// Derived from PARALLEL_SHARDS so adding a new row auto-includes it here.
List<String> expectedStashes() {
  def stashes = []
  eachActiveShard { row, id -> stashes << shardStashName(row, id) }
  return stashes
}

// Pre-create as the unprivileged user so Docker's -v doesn't bind as root.
// Hard-fail on root-owned residue so an admin can sudo rm. Thin wrapper so
// the call sites stay short; helper body lives in _common.groovy.
void cleanPreviousBuildFiles(String buildDir) {
  loadCommonOnce().cleanPreviousBuildFiles(buildDir)
}

// Fail fast on low scratch space so pytest does not hit ENOSPC mid-run.
void checkAgentFreeSpace(int minFreeGB) {
  if (minFreeGB <= 0) { return }
  String target = env.FINN_HOST_BUILD_DIR ?: '/scratch'
  // Climb to the nearest existing ancestor because df on a missing path
  // returns empty and the shard's own dir is not yet mkdir'd.
  def raw = sh(returnStdout: true, script: """
d='${target}'
while [ ! -d "\$d" ] && [ "\$d" != '/' ]; do d=\$(dirname "\$d"); done
df -BG "\$d" | awk 'NR==2 {print \$4}' | tr -d 'G'
""").trim()
  int freeGB = raw.isInteger() ? raw.toInteger() : -1
  echo "checkAgentFreeSpace[${env.NODE_NAME}]: ${freeGB} GB free (probed ${target}, threshold ${minFreeGB} GB)"
  if (freeGB < 0) {
    echo "checkAgentFreeSpace[${env.NODE_NAME}]: could not parse df output (${raw.take(80)}), skipping precheck"
    return
  }
  if (freeGB < minFreeGB) {
    error "agent ${env.NODE_NAME} has only ${freeGB} GB free on ${target} (< ${minFreeGB} GB threshold), aborting shard to avoid mid-run disk exhaustion."
  }
}

// Marker via env var to prevent shell injection. Wrapper script stops
// run-docker.sh re-tokenising the -m argv. Exit-5 mapping lives in
// tests/conftest.py pytest_sessionfinish so the shell wrapper does not
// need to know about pytest exit codes.
//
// run-tests.sh is written at workspace root: that is concurrency-safe
// because each parallel branch runs inside its own node('finn-build') {
// stage(...) } block, and Jenkins gives each concurrent stage on the same
// agent a workspace suffixed with @2/@3/... so two shards never share the
// same workspace path.
void runPytest(Map opts) {
  def parts = ["python -m pytest -m \"\$FINN_CI_MARKER\""]
  if (opts.workers) {
    parts << "-n ${opts.workers} --dist ${opts.distMode ?: 'worksteal'}"
  }
  int numShards = (opts.numShards ?: 0) as int
  if (numShards > 0) {
    parts << "--num-shards ${numShards} --shard-id ${opts.shardId}"
  }
  parts << "--junitxml=${opts.stash}.xml --html=${opts.stash}.html --self-contained-html"
  if (opts.extraArgs) { parts << opts.extraArgs }
  def cmd = parts.join(' ')
  echo "runPytest[${opts.stash}]: FINN_CI_MARKER='${opts.marker}' cmd=${cmd}"
  // FINN_CI_TIMINGS_FILE is optional: when no snapshot is available
  // (cold-start, FINN_CI_NFS_ROOT unset, NFS unreachable, etc) the
  // conftest plugin falls back to deterministic round-robin shard
  // assignment.
  String timingsFile = ''
  if (FINN_CI_TIMINGS_SNAPSHOT && fileExists(FINN_CI_TIMINGS_SNAPSHOT)) {
    timingsFile = "${opts.stash}.timings_input.json"
    sh "cp ${shellQuote(FINN_CI_TIMINGS_SNAPSHOT)} ${shellQuote(timingsFile)}"
  } else if (FINN_CI_TIMINGS_SNAPSHOT) {
    echo "runPytest[${opts.stash}]: ${FINN_CI_TIMINGS_SNAPSHOT} not visible on ${env.NODE_NAME}, falling back to round-robin sharding"
  }
  def envLines = [
      "export FINN_CI_MARKER=${shellQuote(opts.marker as String)}",
      "export FINN_CI_STAGE=${shellQuote(opts.stage as String)}",
      "export FINN_CI_STASH=${shellQuote(opts.stash as String)}",
      "export FINN_CI_JOB_NAME=${shellQuote(env.JOB_NAME ?: '')}",
      "export FINN_CI_BUILD_NUMBER=${shellQuote(env.BUILD_NUMBER ?: '')}",
      "export FINN_CI_TIMINGS_FILE=${shellQuote(timingsFile)}",
  ]
  writeFile file: 'run-tests.sh', text:
      "#!/bin/bash\nset -o pipefail\n${envLines.join('\n')}\n${cmd}\n"
  sh 'chmod 755 run-tests.sh'
  runDockerCommand('./run-docker.sh ./run-tests.sh')
}

void runDockerCommand(String command) { loadCommonOnce().runDockerCommand(command) }

void aggregatePublishedBoardZips() {
  catchError(buildResult: null, stageResult: null,
             message: 'aggregatePublishedBoardZips failed, non-fatal') {
    def pairs = new LinkedHashSet<String>()
    // CPS: see eachActiveShard for the IntRange/closure-serialisation caveat.
    for (int rowIdx = 0; rowIdx < PARALLEL_SHARDS.size(); rowIdx++) {
      Map row = PARALLEL_SHARDS[rowIdx]
      if (!rowIsActive(row)) { continue }
      Map zipArt = row.zipArtifacts as Map
      if (!zipArt) { continue }
      String testType = zipArt.hwTestType as String
      List boards = (zipArt.boards ?: []) as List
      for (int b = 0; b < boards.size(); b++) {
        pairs << "${testType}/${boards[b]}"
      }
    }
    def pairsList = pairs as List
    for (int p = 0; p < pairsList.size(); p++) {
      def parts = (pairsList[p] as String).split('/', 2)
      publishBoardZip(parts[0], parts[1])
    }
  }
}

void publishBoardZip(String testType, String board) {
  String artifactRoot = artifactBuildRoot()
  if (!artifactRoot) {
    echo "publishBoardZip(${testType}/${board}): local fallback mode, skipping"
    return
  }
  String srcRoot = "${artifactRoot}/deployments/${testType}/${board}"
  if (!fileExists(srcRoot)) {
    echo "publishBoardZip(${testType}/${board}): no staged deployments under ${srcRoot}"
    return
  }
  String destPath = boardZipPath(testType, board)
  int slash = destPath.lastIndexOf('/')
  String destDir = slash >= 0 ? destPath.substring(0, slash) : '.'
  String work = "artifact_zips/${testType}/${board}"
  String noDeployments = "${work}/${board}/.NO_DEPLOYMENTS"
  sh "rm -rf ${shellQuote(work)} && mkdir -p ${shellQuote(work + '/' + board)} ${shellQuote(destDir)}"
  sh "docker/jenkins/scripts/publish_board_zip_stage.sh " +
     "${shellQuote(srcRoot)} ${shellQuote(work + '/' + board)} " +
     "${shellQuote(board)} ${shellQuote(testType)}"
  if (fileExists(noDeployments)) { return }
  String qZip   = shellQuote("${board}.zip")
  String qDest  = shellQuote(destPath)
  String qTmp   = shellQuote(destPath + '.tmp')
  String qReady = shellQuote(destPath + '.READY')
  dir(work) {
    sh "zip -r ${qZip} ${shellQuote(board + '/')}"
    sh "cp ${qZip} ${qTmp}"
    sh "mv -f ${qTmp} ${qDest}"
    sh "sync ${qDest}"
    sh "touch ${qReady}"
  }
}

// Silent no-op when hw_deployment_* is absent or local-fallback mode is
// active. Each shard stages its deployment tree separately, and
// aggregateReports() publishes the one canonical board zip.
void findCopyZip(String testType, String board, String findDir, String copyDir) {
  if (!testType) {
    error "findCopyZip(${board}): row has zipArtifacts.boards but no zipArtifacts.hwTestType"
  }
  String artifactRoot = artifactBuildRoot()
  if (!artifactRoot) { return }
  if (!fileExists("${findDir}")) { return }
  def found = sh(returnStdout: true, script:
      "find ${shellQuote(findDir)} -maxdepth 2 -type d -name ${shellQuote(board)} -path '*/hw_deployment_*/*' | sort"
  ).trim()
  if (!found) { return }
  String stageDir = "${artifactRoot}/deployments/${testType}/${board}/${copyDir}"
  sh """
    set -eu
    stage_dir=${shellQuote(stageDir)}
    board=${shellQuote(board)}
    mkdir -p "\${stage_dir}/\${board}"
    chmod -R u+w "\${stage_dir}/\${board}" 2>/dev/null || true
    rm -rf "\${stage_dir}/\${board:?}/"*
    while IFS= read -r board_dir; do
      [ -n "\${board_dir}" ] || continue
      for model_dir in "\${board_dir}"/*; do
        [ -d "\${model_dir}" ] || continue
        name=\$(basename "\${model_dir}")
        if [ -e "\${stage_dir}/\${board}/\${name}" ]; then
          echo "findCopyZip(${testType}/${board}): duplicate deployment \${name} across hw_deployment dirs"
          exit 1
        fi
        cp -a "\${model_dir}" "\${stage_dir}/\${board}/"
      done
    done <<'EOF'
${found}
EOF
  """
  echo "findCopyZip(${testType}/${board}): staged deployments under ${stageDir}"
}
