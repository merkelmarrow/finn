pipeline {
  agent none
  options {
    timeout(time: 72, unit: 'HOURS')
  }
  parameters {
    booleanParam(name: 'fpgadataflow', defaultValue: false, description: 'Run fpgadataflow tests')
    booleanParam(name: 'sanity', defaultValue: true, description: 'Run sanity hardware and unit tests')
    booleanParam(name: 'end2end', defaultValue: false, description: 'Run end2end tests')
  }
  stages {
    stage('Build Docker Image') {
      agent {
        label 'finn-build'
      }
      environment {
        // Override any DSL-level FINN_DOCKER_PREBUILT setting — this
        // stage must always build so the image exists for test stages
        FINN_DOCKER_PREBUILT = "0"
      }
      steps {
        script {
          // Prune old docker containers
          sh "docker system prune -a -f"
          // Build Docker image so parallel stages don't each rebuild it
          sh "./run-docker.sh echo 'Docker image build complete'"
          // If FINN_DOCKER_SHARED_DIR is set, export the image so other
          // agents can load it via run-docker.sh instead of rebuilding
          if (env.FINN_DOCKER_SHARED_DIR) {
            def dockerTag = sh(returnStdout: true, script: '''
              XRT_DEB_VERSION="${XRT_DEB_VERSION:-xrt_202220.2.14.354_22.04-amd64-xrt}"
              echo "xilinx/finn:$(git describe --always --tags --dirty).${XRT_DEB_VERSION}"
            ''').trim()
            sh "mkdir -p ${env.FINN_DOCKER_SHARED_DIR}"
            sh "echo '${dockerTag}' > ${env.FINN_DOCKER_SHARED_DIR}/finn-docker-tag.txt"
            sh "bash -c 'set -o pipefail; if command -v pigz >/dev/null 2>&1; then COMPRESS=\"pigz -p \$(nproc)\"; else COMPRESS=gzip; fi; docker save \"${dockerTag}\" | \$COMPRESS > ${env.FINN_DOCKER_SHARED_DIR}/finn-docker-image.tar.gz'"
          }
        }
      }
    }
    stage('Run Tests') {
      steps {
        script {
          parallel buildParallelStageMap()
        }
      }
    }
    stage('Check Stage Results') {
      agent {
        label 'finn-build'
      }
      steps {
        script {
          // Ordering note (do NOT reorder without re-reading
          // knowledge/platform/jenkins_ci.md §Known CI Issues #13):
          //   1. unstash everything we expect to have been produced
          //   2. publish junit FIRST — it parses XMLs directly from the
          //      workspace, does NOT touch the agent->controller tar
          //      pipeline, so it always succeeds if any XML was unstashed
          //   3. merge HTMLs (defensive — failure here only loses the
          //      combined report; per-stage HTMLs still archive)
          //   4. archiveArtifacts (defensive — the agent->controller tar
          //      transfer occasionally flakes on stash counts > ~10; see
          //      build #12, "Failed to extract /scratch/.../transfer of 13
          //      files" downgraded the stage to FAILURE *after* every
          //      individual stage had already produced its XML/HTML)
          sh 'mkdir -p reports'
          cleanPreviousBuildFiles('reports')
          dir('reports') {
            expectedStashes().each { name -> unstashIf(name) }
          }

          // Plot what XML files were created during the test run.
          // Run BEFORE archiveArtifacts so a flaky tar transfer in archive
          // can never lose us the test result tree (junit reads files
          // directly from the agent workspace).
          junit allowEmptyResults: true, testResults: 'reports/*.xml'

          // Combine individual HTML files into one final report. Wrapped
          // in catchError because pytest_html_merger occasionally chokes
          // on partial inputs; per-stage HTMLs are still archived below.
          catchError(buildResult: null, stageResult: 'UNSTABLE',
                     message: 'pytest_html_merger failed; per-stage HTMLs still archived below') {
            sh './run-docker.sh pytest_html_merger -i reports/ -o reports/test_report_final.html'
          }

          // Archive the XML & HTML test results. Wrapped in catchError
          // because the agent->controller tar transfer ("transfer of N
          // files") occasionally fails on large stash counts — without
          // this, build #12 lost the entire stage to a transfer hiccup
          // even though every per-stage XML/HTML had already been written.
          catchError(buildResult: null, stageResult: 'UNSTABLE',
                     message: 'archiveArtifacts (xml) transfer failed; reports still on agent workspace') {
            archiveArtifacts artifacts: 'reports/*.xml', allowEmptyArchive: true
          }
          catchError(buildResult: null, stageResult: 'UNSTABLE',
                     message: 'archiveArtifacts (html) transfer failed; reports still on agent workspace') {
            archiveArtifacts artifacts: 'reports/*.html', allowEmptyArchive: true
          }
        }
      }
    }
  }
}

// ---------------------------------------------------------------------------
// Parallel stage assembly
// ---------------------------------------------------------------------------

// Build the map of parallel branches that the 'Run Tests' stage executes.
// Each branch spawns its own node('finn-build') allocation so that Jenkins
// schedules them across the executor pool. Gating on params mirrors the
// `when { ... }` blocks of the previous declarative version.
Map<String, Closure> buildParallelStageMap() {
  def branches = [:]
  if (params.sanity) {
    // Sanity - Build Hardware rebuilds exactly the 4 scenarios (lfc-w1a1 on
    // Pynq-Z1, cnv-w1a2 on ZCU104, tfc-w2a2 on KV260, cnv-w2a2 on U250) that
    // the BNN end2end stages also build when end2end=true, so it is
    // redundant in the full-matrix case. Skip it then. See
    // knowledge/analyses/finn_ci_12h_15exec_parallelisation.md §3.3.
    if (!params.end2end) {
      branches['Sanity - Build Hardware'] = { sanityBuildHardwareStage() }
    }
    branches['Sanity - Unit Tests'] = { sanityUnitTestsStage() }
  }
  if (params.fpgadataflow) {
    branches['fpgadataflow - shard A'] = { fpgadataflowShardStage('a', FPGADATAFLOW_SHARD_A) }
    branches['fpgadataflow - shard B'] = { fpgadataflowShardStage('b', FPGADATAFLOW_SHARD_B) }
  }
  if (params.end2end) {
    // mobilenet_v1 dominates end2end wall-clock and benefits from the full
    // worker pool; the lighter shard (bnn_pynq non-sanity + cybsec + ooc +
    // ext_weights) runs comfortably on fewer workers.
    branches['End2end - mobilenet'] = {
      end2endShardStage('mobilenet', END2END_MOBILENET, (env.NUM_PYTEST_WORKERS ?: '8').toInteger())
    }
    branches['End2end - rest'] = { end2endShardStage('rest', END2END_REST, 4) }
    BNN_SUB_STAGES.each { entry ->
      String board = entry[0]
      String label = entry[1]
      String kExpr = entry[2]
      int nWorkers = entry[3] as int
      branches["BNN ${board} - ${label}"] = { bnnSubStage(board, label, kExpr, nWorkers) }
    }
  }
  return branches
}

// ---------------------------------------------------------------------------
// Stage bodies (one per parallel branch)
// ---------------------------------------------------------------------------

// Stage-body pattern (read this before editing any of the 5 stages below):
//
//   withEnv([...]) {
//     cleanPreviousBuildFiles(buildDir)   // safe to call before pytest
//     try {
//       catchError(stageResult: 'FAILURE') {
//         runDockerPytest...(...)         // throws on pytest exit != 0
//         // post-success-only artefact extraction (skipped on throw)
//       }
//     } finally {
//       safeStashReport(stashName)        // ALWAYS runs (pass/fail/abort)
//       archiveIfStageRan(...)            // optional, defensive
//     }
//   }
//
// catchError wraps ONLY the steps that may throw "expected" failures
// (pytest exit-1, findCopyZip missing artefacts). safeStashReport MUST
// live in a `finally` block so it runs regardless of whether pytest
// passed or failed — otherwise `Check Stage Results` cannot aggregate
// JUnit XMLs for failed stages and the build's test counts drop the
// failing stages entirely. See knowledge/platform/jenkins_ci.md
// §Known CI Issues #12 for the full diagnosis (build #12 lost the XMLs
// for sanity_ut, fpgadataflow_a/b, end2end_mobilenet/rest this way).

void sanityBuildHardwareStage() {
  node('finn-build') {
    stage('Sanity - Build Hardware') {
      checkout scm
      def testName = 'bnn_build_sanity'
      def buildDir = "${env.FINN_HOST_BUILD_DIR}/${testName}"
      withEnv(["FINN_HOST_BUILD_DIR=${buildDir}"]) {
        sh "mkdir -p ${testName}"
        cleanPreviousBuildFiles(buildDir)
        try {
          catchError(stageResult: 'FAILURE') {
            runDockerPytestWithMarker('sanity_bnn', testName, '')
            // Ship every board's hw_deployment artefacts to ARTIFACT_DIR so
            // downstream board-HW jobs can pick them up. Skipped if pytest
            // failed (catchError swallows the throw and exits the closure).
            ['Pynq-Z1', 'ZCU104', 'KV260_SOM', 'U250'].each { b ->
              findCopyZip(b, buildDir, testName)
            }
          }
        } finally {
          safeStashReport(testName)
        }
      }
    }
  }
}

void sanityUnitTestsStage() {
  node('finn-build') {
    stage('Sanity - Unit Tests') {
      checkout scm
      def testName = 'sanity_ut'
      def buildDir = "${env.FINN_HOST_BUILD_DIR}/${testName}"
      withEnv(["FINN_HOST_BUILD_DIR=${buildDir}"]) {
        cleanPreviousBuildFiles(buildDir)
        try {
          catchError(stageResult: 'FAILURE') {
            runDockerPytestWithMarker(
                'util or brevitas_export or streamline or transform or notebooks',
                testName,
                "-n ${env.NUM_PYTEST_WORKERS} --dist worksteal --cov --cov-report=html:coverage_${testName}"
            )
          }
        } finally {
          safeStashReport(testName)
          archiveIfStageRan(testName, "coverage_${testName}")
        }
      }
    }
  }
}

void fpgadataflowShardStage(String shardId, List<String> paths) {
  node('finn-build') {
    stage("fpgadataflow - shard ${shardId}") {
      checkout scm
      def testName = "fpgadataflow_${shardId}"
      def buildDir = "${env.FINN_HOST_BUILD_DIR}/${testName}"
      def nWorkers = (env.NUM_PYTEST_WORKERS ?: '8').toInteger()
      withEnv(["FINN_HOST_BUILD_DIR=${buildDir}"]) {
        cleanPreviousBuildFiles(buildDir)
        try {
          catchError(stageResult: 'FAILURE') {
            runDockerPytestShard(
                'fpgadataflow',
                testName,
                paths,
                nWorkers,
                "--cov --cov-report=html:coverage_${testName}"
            )
          }
        } finally {
          safeStashReport(testName)
          archiveIfStageRan(testName, "coverage_${testName}")
        }
      }
    }
  }
}

void end2endShardStage(String shardId, List<String> paths, int nWorkers) {
  node('finn-build') {
    stage("End2end - ${shardId}") {
      checkout scm
      def testName = "end2end_${shardId}"
      def buildDir = "${env.FINN_HOST_BUILD_DIR}/${testName}"
      withEnv(["FINN_HOST_BUILD_DIR=${buildDir}"]) {
        cleanPreviousBuildFiles(buildDir)
        try {
          catchError(stageResult: 'FAILURE') {
            // Every end2end scenario already carries an xdist_group marker, so
            // scenarios fan out across workers without cross-talk.
            runDockerPytestShard('end2end', testName, paths, nWorkers, '')
          }
        } finally {
          safeStashReport(testName)
        }
      }
    }
  }
}

// Run a single BNN end2end sub-stage: marker selects the board, -k narrows
// to the scenario bucket defined in BNN_SUB_STAGES. Only the sub-stage that
// actually builds cnv-w2a2 zips hw_deployment artefacts for the board-HW
// job — that scenario is what gets validated on the physical board.
void bnnSubStage(String board, String label, String kExpr, int nWorkers) {
  node('finn-build') {
    stage("BNN ${board} - ${label}") {
      checkout scm
      def marker = BNN_BOARD_MARKERS[board]
      def stashName = bnnStashName(board, label)
      def buildDir = "${env.FINN_HOST_BUILD_DIR}/${stashName}"
      withEnv(["FINN_HOST_BUILD_DIR=${buildDir}"]) {
        sh "mkdir -p ${stashName}"
        cleanPreviousBuildFiles(buildDir)
        try {
          catchError(stageResult: 'FAILURE') {
            // BNN end2end tests have a strict sequential dependency chain: each
            // test_* loads the previous step's checkpoint via
            // load_test_checkpoint_or_skip. xdist `--dist worksteal` lets idle
            // workers steal from busy ones across xdist_group boundaries, which
            // executes tests out of declaration order and silently breaks the
            // chain (every downstream test then skips). `--dist loadgroup`
            // pins entire xdist_group cohorts to a single worker AND processes
            // them sequentially in collection order. See build #10:
            // bnn_KV260_SOM_cnv_w2a2 ran test_cppsim before test_export.
            runDockerPytestWithMarker(
                marker,
                stashName,
                "-k '${kExpr}' -n ${nWorkers} --dist loadgroup"
            )
            // hw_deployment artefacts only get shipped on full success;
            // catchError above swallows pytest throws so this is skipped
            // when tests fail (incomplete artefacts aren't useful anyway).
            if (label == 'cnv-w2a2') {
              findCopyZip(board, buildDir, stashName)
            }
          }
        } finally {
          safeStashReport(stashName)
        }
      }
    }
  }
}

// Canonical stash / pytest-junit / env-var suffix for a BNN sub-stage.
// Board and label dashes are collapsed to underscores so the string is safe
// as both a filesystem path and an env-var suffix (e.g. Pynq-Z1 + cnv-w2a2
// → bnn_Pynq_Z1_cnv_w2a2).
String bnnStashName(String board, String label) {
  return "bnn_${board}_${label}".replaceAll('-', '_')
}

// ---------------------------------------------------------------------------
// Shell / pytest helpers (behaviour preserved from pre-refactor version)
// ---------------------------------------------------------------------------

void cleanPreviousBuildFiles(String buildDir) {
  // Delete any build files from a previous build
  // Previous build folders affect findCopyZip() and can cause the stage to fail
  if (!buildDir.empty) {
      sh "rm -rf ${buildDir}"
  }
}

// All pytest invocations go through a shell script file (run-tests.sh)
// rather than being passed inline to run-docker.sh. run-docker.sh joins its
// arguments into a single string and re-tokenises them, which breaks any
// argument that contains shell metacharacters — for example pytest's
// `-k '(cnv and w2a2) or tfc'` or `-m 'util or brevitas_export'`. Writing
// the command into a script and feeding that script to run-docker.sh lets
// the in-container bash parse it with full quoting semantics intact.
//
// --forked was dropped in favour of pytest-xdist's native per-worker
// process isolation. pytest-forked is deprecated upstream; xdist with
// --dist worksteal already runs each test in a dedicated worker process.
void runPytestScript(String pytestBody) {
  writeFile file: 'run-tests.sh', text: "#!/bin/bash\nset -eo pipefail\n${pytestBody}\n"
  sh 'chmod 777 run-tests.sh'
  sh './run-docker.sh ./run-tests.sh'
}

void runDockerPytestWithMarker(String marker, String testResultsFilename, String additionalOptions) {
  runPytestScript(
      "python -m pytest -m '${marker}'" +
      " --junitxml=${testResultsFilename}.xml" +
      " --html=${testResultsFilename}.html --self-contained-html" +
      " ${additionalOptions}"
  )
}

// Run pytest filtered by marker and restricted to an explicit list of file
// paths (used for End2end and fpgadataflow sharding). Uses pytest-xdist
// with `--dist loadgroup` so that tests carrying the same xdist_group mark
// are pinned to the same worker AND run in collection order. The end2end
// suites depend on per-scenario checkpoints written by earlier tests in
// the same group; `--dist worksteal` allowed idle workers to steal across
// groups and executed tests out of order, silently skipping the chain
// (build #10, bnn_KV260_SOM_cnv_w2a2: test_cppsim ran before test_export).
// fpgadataflow tests are independent so loadgroup degenerates to load there.
void runDockerPytestShard(String marker, String testResultsFilename, List<String> paths, int nWorkers, String additionalOptions) {
  def pathArgs = paths.join(' ')
  runPytestScript(
      "python -m pytest -m '${marker}' ${pathArgs}" +
      " -n ${nWorkers} --dist loadgroup" +
      " --junitxml=${testResultsFilename}.xml" +
      " --html=${testResultsFilename}.html --self-contained-html" +
      " ${additionalOptions}"
  )
}

void findCopyZip(String board, String findDir, String copyDir) {
  sh "mkdir -p ${copyDir}"
  try {
    sh "cp -r ${findDir}/hw_deployment_*/${board} ${copyDir}/"
    dir(copyDir) {
      sh "zip -r ${board}.zip ${board}/"
      sh "mkdir -p ${env.ARTIFACT_DIR}/${copyDir}/"
      sh "cp ${board}.zip ${env.ARTIFACT_DIR}/${copyDir}/"
    }
  } catch (err) {
    error "No ${board} hw_deployment_* build artifacts found in ${findDir}"
  }
}

// Stash the per-stage XML+HTML report iff pytest produced an XML, and
// flip the STAGE_RAN_<name> env var so Check Stage Results knows to
// unstash it. Designed to live in a `finally` block so it ALWAYS runs,
// regardless of whether pytest passed, failed, or aborted — pytest
// emits its junitxml on every exit code (pass, fail, collection error,
// keyboard interrupt) so an XML existing on disk is the right "we have
// something to aggregate" signal. The contract is intentionally:
//   "STAGE_RAN_<name> means we stashed an XML"
// NOT:
//   "STAGE_RAN_<name> means pytest passed".
// Pass/fail status comes from the JUnit XMLs themselves and from the
// stage's own catchError(stageResult: 'FAILURE') marking — which is
// completely orthogonal to whether we managed to ship the report.
//
// Wrapped in catchError(buildResult: null, stageResult: null) so a
// stash hiccup (NFS blip, full disk on the controller) cannot turn a
// pure test-result-archive operation into a build-status-affecting
// failure. The stage's pass/fail is already determined by the catchError
// around the pytest invocation itself.
//
// Sandbox note: dynamically-keyed access on `env` (which is EnvActionImpl,
// not a plain Map) compiles to the static helpers
// org.codehaus.groovy.runtime.DefaultGroovyMethods.putAt(Object,String,Object)
// and getAt(Object,String). These are NOT in the script-security default
// allowlist, so Jenkins rejected build #11 cnv-w2a1 with "Scripts not
// permitted to use staticMethod ... DefaultGroovyMethods putAt ...". Both
// signatures are now persisted in the ansible-managed
// jenkins_script_security.yml allowlist for this controller; do not switch
// to env.setProperty(name,val) / env.getProperty(name) without first adding
// "method org.jenkinsci.plugins.workflow.cps.EnvActionImpl setProperty
// java.lang.String java.lang.Object" and "... getProperty java.lang.String"
// to that allowlist — those instance methods on EnvActionImpl are NOT
// @Whitelisted by the pipeline plugin (verified via Script Console,
// 2026-04-19). Full diagnosis: knowledge/platform/jenkins_ci.md §Known
// CI Issues #11.
void safeStashReport(String stashName) {
  catchError(buildResult: null, stageResult: null,
             message: "safeStashReport(${stashName}) failed; non-fatal, junit aggregation may be partial") {
    if (fileExists("${stashName}.xml")) {
      stash name: stashName, includes: "${stashName}.xml,${stashName}.html"
      env["STAGE_RAN_${stashName}"] = 'SUCCESS'
    }
  }
}

// Unstash <stashName> iff the owning stage produced an XML and stashed
// it (i.e. safeStashReport flipped the env flag). No-op otherwise.
void unstashIf(String stashName) {
  if (env["STAGE_RAN_${stashName}"]) {
    unstash stashName
  }
}

// Archive a coverage (or similar) folder iff the owning stage produced
// a stash. Wrapped in catchError so a missing/empty coverage dir doesn't
// fail the stage on top of whatever already happened.
void archiveIfStageRan(String stashName, String folder) {
  if (env["STAGE_RAN_${stashName}"]) {
    catchError(buildResult: null, stageResult: null,
               message: "archiveArtifacts(${folder}) failed; non-fatal") {
      archiveArtifacts artifacts: "${folder}/**/*", allowEmptyArchive: true
    }
  }
}

// ---------------------------------------------------------------------------
// Check Stage Results — driven by the same tables the parallel block uses
// ---------------------------------------------------------------------------

// List of every stash we expect the current run to produce, in the order
// they should appear in the aggregated report. Derived directly from the
// params + the shard / sub-stage tables, so adding a sub-stage anywhere
// (or flipping a param) updates the aggregation automatically.
List<String> expectedStashes() {
  def stashes = []
  if (params.sanity) {
    stashes << 'sanity_ut'
    if (!params.end2end) {
      stashes << 'bnn_build_sanity'
    }
  }
  if (params.fpgadataflow) {
    stashes += ['fpgadataflow_a', 'fpgadataflow_b']
  }
  if (params.end2end) {
    stashes += ['end2end_mobilenet', 'end2end_rest']
    BNN_SUB_STAGES.each { entry ->
      stashes << bnnStashName(entry[0], entry[1])
    }
  }
  return stashes
}
