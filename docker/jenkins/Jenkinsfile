// =============================================================================
// Constants
// =============================================================================

// Must match the tag computed by run-docker.sh; XRT_DEB_VERSION default
// is mirrored there so a missing env var doesn't silently mismatch.
@Field
final String DEFAULT_XRT_DEB_VERSION = 'xrt_202220.2.14.354_22.04-amd64-xrt'

// =============================================================================
// Pipeline
// =============================================================================

pipeline {
  agent none
  options {
    timeout(time: 72, unit: 'HOURS')
  }
  parameters {
    booleanParam(name: 'fpgadataflow', defaultValue: false, description: 'Run fpgadataflow tests')
    booleanParam(name: 'sanity', defaultValue: true, description: 'Run sanity hardware and unit tests')
    booleanParam(name: 'end2end', defaultValue: false, description: 'Run end2end tests')
  }
  stages {
    stage('Build Docker Image') {
      agent { label 'finn-build' }
      // Override any DSL-level FINN_DOCKER_PREBUILT=1 — this stage must
      // build so subsequent test stages have an image to load.
      environment { FINN_DOCKER_PREBUILT = '0' }
      steps {
        script { buildAndPublishDockerImage() }
      }
    }
    stage('Run Tests') {
      steps { script { parallel(buildParallelStageMap()) } }
    }
    stage('Check Stage Results') {
      agent { label 'finn-build' }
      steps { script { aggregateReports() } }
    }
  }
}

// =============================================================================
// Stage builders
// =============================================================================

void buildAndPublishDockerImage() {
  sh 'docker system prune -a -f'
  sh "./run-docker.sh echo 'Docker image build complete'"
  if (env.FINN_DOCKER_SHARED_DIR) {
    publishSharedDockerImage(env.FINN_DOCKER_SHARED_DIR)
  }
}

// Push the freshly-built image to FINN_DOCKER_SHARED_DIR so other agents
// `docker load` it via run-docker.sh instead of rebuilding. The tag must
// match what run-docker.sh computes from `git describe` + XRT_DEB_VERSION.
void publishSharedDockerImage(String sharedDir) {
  def tag = sh(returnStdout: true, script:
      "echo \"xilinx/finn:\$(git describe --always --tags --dirty).\${XRT_DEB_VERSION:-${DEFAULT_XRT_DEB_VERSION}}\""
  ).trim()
  sh "mkdir -p ${sharedDir}"
  sh "echo '${tag}' > ${sharedDir}/finn-docker-tag.txt"
  // pigz uses all cores; fall back to gzip when the agent lacks it.
  sh """
    set -o pipefail
    if command -v pigz >/dev/null 2>&1; then
      docker save '${tag}' | pigz -p \$(nproc) > '${sharedDir}/finn-docker-image.tar.gz'
    else
      docker save '${tag}' | gzip > '${sharedDir}/finn-docker-image.tar.gz'
    fi
  """
}

Map<String, Closure> buildParallelStageMap() {
  def branches = [:]
  if (params.sanity) {
    // Sanity-Build-Hardware rebuilds the same 4 scenarios that the BNN
    // sub-stages already build when end2end=true; skip it then.
    if (!params.end2end) {
      branches['Sanity - Build Hardware'] = { sanityBuildHardwareStage() }
    }
    branches['Sanity - Unit Tests'] = { sanityUnitTestsStage() }
  }
  if (params.fpgadataflow) {
    branches['fpgadataflow - shard A'] = { fpgadataflowShardAStage() }
    branches['fpgadataflow - shard B'] = { fpgadataflowShardBStage() }
  }
  if (params.end2end) {
    branches['End2end - mobilenet'] = { end2endShardStage('mobilenet', END2END_MOBILENET, defaultWorkers()) }
    branches['End2end - rest']      = { end2endShardStage('rest',      END2END_REST,      4) }
    BNN_SUB_STAGES.each { entry ->
      branches["BNN ${entry.board} - ${entry.label}"] = { bnnSubStage(entry) }
    }
  }
  return branches
}

// =============================================================================
// Stage bodies — every parallel branch routes through testStage(), which
// guarantees the report stash runs in `finally` so failed stages still
// publish their JUnit XML. Do not move the stash out of the `finally`.
// =============================================================================

void sanityBuildHardwareStage() {
  testStage('Sanity - Build Hardware', 'bnn_build_sanity') { stashName, buildDir ->
    runPytest(marker: 'sanity_bnn', stash: stashName)
    ['Pynq-Z1', 'ZCU104', 'KV260_SOM', 'U250'].each { board ->
      findCopyZip(board, buildDir, stashName)
    }
  }
}

void sanityUnitTestsStage() {
  testStage('Sanity - Unit Tests', 'sanity_ut') { stashName, buildDir ->
    runPytest(
        marker: 'util or brevitas_export or streamline or transform or notebooks',
        stash: stashName,
        workers: defaultWorkers(),
        extraArgs: "--cov --cov-report=html:coverage_${stashName}",
    )
    archiveStageFolder("coverage_${stashName}")
  }
}

void fpgadataflowShardAStage() {
  testStage('fpgadataflow - shard A', 'fpgadataflow_a') { stashName, buildDir ->
    runPytest(
        marker: 'fpgadataflow',
        stash: stashName,
        files: FPGADATAFLOW_SHARD_A,
        workers: defaultWorkers(),
        extraArgs: "--cov --cov-report=html:coverage_${stashName}",
    )
    archiveStageFolder("coverage_${stashName}")
  }
}

void fpgadataflowShardBStage() {
  // Shard B = "everything under tests/fpgadataflow/ that is not in shard A",
  // so a newly-added test file lands here automatically.
  testStage('fpgadataflow - shard B', 'fpgadataflow_b') { stashName, buildDir ->
    runPytest(
        marker: 'fpgadataflow',
        stash: stashName,
        files: ['tests/fpgadataflow/'],
        ignore: FPGADATAFLOW_SHARD_A,
        workers: defaultWorkers(),
        extraArgs: "--cov --cov-report=html:coverage_${stashName}",
    )
    archiveStageFolder("coverage_${stashName}")
  }
}

void end2endShardStage(String shardId, List<String> files, int workers) {
  testStage("End2end - ${shardId}", "end2end_${shardId}") { stashName, buildDir ->
    runPytest(marker: 'end2end', stash: stashName, files: files,
              workers: workers, distMode: 'loadgroup')
  }
}

// `--dist loadgroup` is REQUIRED for BNN end2end correctness — workers
// stealing across xdist_group boundaries (worksteal default) breaks the
// load_test_checkpoint_or_skip dependency chain and silently skips
// downstream tests. Build #10 KV260 cnv-w2a2 hit this; do not change.
void bnnSubStage(Map entry) {
  String marker = BNN_BOARD_MARKERS[entry.board]
  String name   = bnnStashName(entry.board, entry.label)
  testStage("BNN ${entry.board} - ${entry.label}", name) { stashName, buildDir ->
    runPytest(
        marker: marker,
        stash: stashName,
        keyword: entry.keyword,
        workers: entry.workers as int,
        distMode: 'loadgroup',
    )
    // Only the cnv-w2a2 sub-stage produces the artefacts the board-HW
    // job consumes (that is what gets validated on the physical board).
    if (entry.label == 'cnv-w2a2') {
      findCopyZip(entry.board, buildDir, stashName)
    }
  }
}

// Stash names double as filesystem paths and env-var suffixes, so dashes are
// normalised to underscores: e.g. Pynq-Z1 + cnv-w2a2 -> bnn_Pynq_Z1_cnv_w2a2.
String bnnStashName(String board, String label) {
  return "bnn_${board}_${label}".replaceAll('-', '_')
}

// =============================================================================
// Test-stage scaffolding
// =============================================================================

// Run `body(stashName, buildDir)` inside a finn-build node, with the standard
// per-stage build-dir + report-stash plumbing. The body runs inside
// catchError(stageResult: 'FAILURE') so an expected pytest failure marks
// the stage FAILURE without aborting the pipeline; the stash itself runs in
// `finally` so failed stages still publish their JUnit XMLs.
void testStage(String stageName, String stashName, Closure body) {
  node('finn-build') {
    stage(stageName) {
      checkout scm
      def buildDir = "${env.FINN_HOST_BUILD_DIR}/${stashName}"
      withEnv(["FINN_HOST_BUILD_DIR=${buildDir}"]) {
        sh "mkdir -p ${stashName}"
        cleanPreviousBuildFiles(buildDir)
        try {
          catchError(stageResult: 'FAILURE') {
            body.call(stashName, buildDir)
          }
        } finally {
          safeStashReport(stashName)
        }
      }
    }
  }
}

// Stash <stash>.xml + <stash>.html iff pytest produced an XML. Defensive
// catchError ensures a stash hiccup (NFS blip, controller disk full) cannot
// affect build status — the stage's own catchError around pytest already
// determines pass/fail.
void safeStashReport(String stashName) {
  catchError(buildResult: null, stageResult: null,
             message: "safeStashReport(${stashName}) failed; aggregation may be partial") {
    if (fileExists("${stashName}.xml")) {
      stash name: stashName, includes: "${stashName}.xml,${stashName}.html"
    }
  }
}

// unstash throws if the stash never happened (stage skipped or failed pre-stash);
// swallow that one specific case so aggregation continues. We use try/catch
// rather than a tracking @Field collection because the latter would require
// thread-safe sandbox-approved JDK collection types for parallel branches.
void unstashIfPresent(String stashName) {
  try {
    unstash stashName
  } catch (Exception ignored) {
    echo "No stash named '${stashName}' (stage was skipped or failed before publishing reports)"
  }
}

void archiveStageFolder(String folder) {
  catchError(buildResult: null, stageResult: null,
             message: "archiveArtifacts(${folder}) failed; non-fatal") {
    archiveArtifacts artifacts: "${folder}/**/*", allowEmptyArchive: true
  }
}

// =============================================================================
// Aggregation
// =============================================================================

// Order is load-bearing: junit FIRST (workspace-local, never flakes), then
// defensive merge + archive (agent->controller tar transfer can flake on
// glob counts > ~10). Reversing this loses the test result tree on transfer
// flake even when every per-stage XML is on disk.
void aggregateReports() {
  sh 'mkdir -p reports'
  cleanPreviousBuildFiles('reports')
  dir('reports') {
    expectedStashes().each { name -> unstashIfPresent(name) }
  }
  junit allowEmptyResults: true, testResults: 'reports/*.xml'
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'pytest_html_merger failed; per-stage HTMLs still archived below') {
    sh './run-docker.sh pytest_html_merger -i reports/ -o reports/test_report_final.html'
  }
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'archiveArtifacts (xml) transfer failed') {
    archiveArtifacts artifacts: 'reports/*.xml', allowEmptyArchive: true
  }
  catchError(buildResult: null, stageResult: 'UNSTABLE',
             message: 'archiveArtifacts (html) transfer failed') {
    archiveArtifacts artifacts: 'reports/*.html', allowEmptyArchive: true
  }
}

// Derived from the same tables the parallel block uses, so adding a sub-stage
// or flipping a param updates aggregation automatically.
List<String> expectedStashes() {
  def stashes = []
  if (params.sanity) {
    stashes << 'sanity_ut'
    if (!params.end2end) {
      stashes << 'bnn_build_sanity'
    }
  }
  if (params.fpgadataflow) {
    stashes += ['fpgadataflow_a', 'fpgadataflow_b']
  }
  if (params.end2end) {
    stashes += ['end2end_mobilenet', 'end2end_rest']
    BNN_SUB_STAGES.each { entry -> stashes << bnnStashName(entry.board, entry.label) }
  }
  return stashes
}

// =============================================================================
// Shell helpers
// =============================================================================

void cleanPreviousBuildFiles(String buildDir) {
  if (buildDir && !buildDir.empty) {
    sh "rm -rf ${buildDir}"
  }
}

int defaultWorkers() {
  return (env.NUM_PYTEST_WORKERS ?: '8').toInteger()
}

// Single pytest entry point. Builds the command line from named arguments
// and feeds it to run-docker.sh via a temporary script; run-docker.sh
// re-tokenises its argv, so quoted shell metacharacters (e.g. -k '... or ...')
// don't survive a direct `./run-docker.sh python -m pytest -k '...'` call.
//
// Args (Map):
//   marker    : pytest -m expression                  (required)
//   stash     : test-results filename stem            (required)
//   keyword   : pytest -k expression                  (optional)
//   files     : list of test paths or directories     (optional)
//   ignore    : list of paths to --ignore             (optional)
//   workers   : xdist -n value                        (optional; if omitted, no -n)
//   distMode  : --dist value, defaults to 'worksteal' when workers > 0
//   extraArgs : free-form extra pytest args           (optional)
//
// pytest-forked dropped — pytest-xdist already provides per-worker process
// isolation, and pytest-forked is deprecated upstream.
void runPytest(Map opts) {
  def parts = ["python -m pytest -m '${opts.marker}'"]
  if (opts.files)   { parts << opts.files.join(' ') }
  if (opts.keyword) { parts << "-k '${opts.keyword}'" }
  (opts.ignore ?: []).each { parts << "--ignore=${it}" }
  if (opts.workers) {
    parts << "-n ${opts.workers} --dist ${opts.distMode ?: 'worksteal'}"
  }
  parts << "--junitxml=${opts.stash}.xml --html=${opts.stash}.html --self-contained-html"
  if (opts.extraArgs) { parts << opts.extraArgs }
  writeFile file: 'run-tests.sh', text: "#!/bin/bash\nset -eo pipefail\n${parts.join(' ')}\n"
  sh 'chmod 777 run-tests.sh'
  sh './run-docker.sh ./run-tests.sh'
}

void findCopyZip(String board, String findDir, String copyDir) {
  sh "mkdir -p ${copyDir}"
  try {
    sh "cp -r ${findDir}/hw_deployment_*/${board} ${copyDir}/"
    dir(copyDir) {
      sh "zip -r ${board}.zip ${board}/"
      sh "mkdir -p ${env.ARTIFACT_DIR}/${copyDir}/"
      sh "cp ${board}.zip ${env.ARTIFACT_DIR}/${copyDir}/"
    }
  } catch (err) {
    error "No ${board} hw_deployment_* build artifacts found in ${findDir}"
  }
}
